  <span style="opacity:.3">·</span>
  <a href="<%- termsUrl || '/terms' %>" style="color:var(--text-2);text-decoration:none;margin:0 10px" onmouseover="this.style.color='var(--text-hi)'" onmouseout="this.style.color='var(--text-2)'">Terms of Service</a>
</footer>
</body>
