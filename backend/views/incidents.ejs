<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= pageTitle %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --accent: <%= accentColor %>;
  --bg:#0a0a0a;--surface:#141414;--surface2:#1a1a1a;
  --border:rgba(255,255,255,0.06);--border-hi:rgba(255,255,255,0.10);
  --text:#a0a0a0;--text-2:#6f6f6f;--text-hi:#d4d4d4;--text-white:#f5f5f5;
  --shadow:rgba(0,0,0,0.5);
  --ga:rgba(255,140,42,0.08);
  --accent-soft:color-mix(in srgb,var(--accent) 12%,transparent);
  --sans:'Plus Jakarta Sans',sans-serif;--mono:'JetBrains Mono',monospace;
  --r:14px;--r-sm:10px;
  --green:#39d98a;--orange:#f59e0b;--red:#ef4444;--purple:#8b5cf6;
}
body{font-family:var(--sans);background:<%= bgColor || 'var(--bg)' %>;color:var(--text);min-height:100vh;-webkit-font-smoothing:antialiased}
.bg-glow{position:fixed;inset:0;pointer-events:none;background:radial-gradient(ellipse 70% 60% at 50% 20%,var(--ga) 0%,transparent 70%)}
.wrap{position:relative;z-index:1;max-width:820px;margin:0 auto;padding:48px 24px 80px}
.back{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--text-2);text-decoration:none;margin-bottom:32px;transition:color .15s}
.back:hover{color:var(--text-hi)}
.brand{display:flex;align-items:center;gap:12px;margin-bottom:32px}
.brand-logo{width:<%= logoSize %>px;height:<%= logoSize %>px;border-radius:10px;background:var(--accent-soft);border:1px solid rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;font-size:18px;overflow:hidden}
.brand-logo img{width:100%;height:100%;object-fit:cover}
.brand-name{font-size:20px;font-weight:700;color:var(--text-white);letter-spacing:-.02em}
h1{font-size:30px;font-weight:700;color:var(--text-white);letter-spacing:-.02em;margin-bottom:8px}
.subtitle{font-size:14px;color:var(--text-2);margin-bottom:40px}
.section-label{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-2);margin:32px 0 14px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.empty{padding:32px 24px;text-align:center;color:var(--text-2);background:var(--surface);border:1px solid var(--border);border-radius:var(--r);font-size:14px}
.incident{background:var(--surface);border:1px solid var(--border-hi);border-radius:var(--r);margin-bottom:18px;overflow:hidden}
.incident.open{border-color:rgba(239,68,68,.35);box-shadow:0 0 0 1px rgba(239,68,68,.15)}
.inc-head{padding:18px 22px;border-bottom:1px solid var(--border)}
.inc-title{display:flex;align-items:flex-start;gap:12px;margin-bottom:10px}
.inc-title h2{font-size:18px;font-weight:700;color:var(--text-white);flex:1;letter-spacing:-.01em;line-height:1.3}
.badges{display:flex;flex-wrap:wrap;gap:8px;align-items:center;font-size:11px;font-weight:600;letter-spacing:.04em}
.badge{padding:4px 10px;border-radius:20px;text-transform:uppercase}
.badge.status-investigating{background:rgba(239,68,68,.15);color:#ef4444;border:1px solid rgba(239,68,68,.3)}
.badge.status-identified{background:rgba(245,158,11,.15);color:#f59e0b;border:1px solid rgba(245,158,11,.3)}
.badge.status-monitoring{background:rgba(139,92,246,.15);color:#a78bfa;border:1px solid rgba(139,92,246,.3)}
.badge.status-resolved{background:rgba(57,217,138,.15);color:#39d98a;border:1px solid rgba(57,217,138,.3)}
.badge.impact-minor{background:var(--surface2);color:var(--text);border:1px solid var(--border-hi)}
.badge.impact-major{background:rgba(245,158,11,.1);color:#f59e0b;border:1px solid rgba(245,158,11,.25)}
.badge.impact-critical{background:rgba(239,68,68,.1);color:#ef4444;border:1px solid rgba(239,68,68,.25)}
.inc-meta{display:flex;flex-wrap:wrap;gap:16px;font-size:12px;color:var(--text-2);margin-top:6px}
.inc-meta strong{color:var(--text-hi);font-weight:600}
.updates{padding:14px 22px 18px}
.update{position:relative;padding:12px 0 12px 26px;border-left:2px solid var(--border-hi)}
.update:last-child{padding-bottom:0}
.update::before{content:"";position:absolute;left:-6px;top:16px;width:10px;height:10px;border-radius:50%;background:var(--text-2);border:2px solid var(--surface)}
.update.investigating::before{background:#ef4444}
.update.identified::before{background:#f59e0b}
.update.monitoring::before{background:#a78bfa}
.update.resolved::before{background:#39d98a}
.update-head{display:flex;align-items:center;gap:10px;margin-bottom:4px}
.update-status{font-size:11px;font-weight:700;letter-spacing:.05em;text-transform:uppercase}
.update-status.investigating{color:#ef4444}
.update-status.identified{color:#f59e0b}
.update-status.monitoring{color:#a78bfa}
.update-status.resolved{color:#39d98a}
.update-time{font-size:11px;color:var(--text-2);font-family:var(--mono)}
.update-msg{font-size:13px;line-height:1.6;color:var(--text-hi);white-space:pre-wrap;word-wrap:break-word}
.skeleton{height:120px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);animation:pulse 1.4s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@media (max-width:600px){.wrap{padding:28px 16px 60px}h1{font-size:24px}}
</style>
</head>
<body>
<div class="bg-glow"></div>

<div class="wrap">
  <a class="back" href="/">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    Back to status dashboard
  </a>

  <div class="brand">
    <div class="brand-logo">
      <% if (logoImage) { %>
        <img src="<%= logoImage %>" alt="<%= groupName %>">
      <% } else { %>
        <%= logoText || groupName.charAt(0).toUpperCase() %>
      <% } %>
    </div>
    <div class="brand-name"><%= groupName %></div>
  </div>

  <h1>Incident History</h1>
  <p class="subtitle">Operational updates for <%= groupName %>.</p>

  <div id="openSection" style="display:none">
    <div class="section-label">Active Incidents</div>
    <div id="openList"></div>
  </div>

  <div id="recentSection">
    <div class="section-label">Past Incidents</div>
    <div id="recentList">
      <div class="skeleton"></div>
    </div>
  </div>
</div>

<footer style="text-align:center;padding:24px 16px;font-size:12px;color:var(--text-2)">
  <% if (privacyUrl || termsUrl) { %>
    <% if (privacyUrl) { %><a href="<%= privacyUrl %>" style="color:var(--text-2);text-decoration:none;margin:0 8px" onmouseover="this.style.color='var(--text-hi)'" onmouseout="this.style.color='var(--text-2)'">Privacy</a><% } %>
    <% if (privacyUrl && termsUrl) { %>·<% } %>
    <% if (termsUrl) { %><a href="<%= termsUrl %>" style="color:var(--text-2);text-decoration:none;margin:0 8px" onmouseover="this.style.color='var(--text-hi)'" onmouseout="this.style.color='var(--text-2)'">Terms</a><% } %>
  <% } %>
</footer>

<script>
const GROUP_SLUG = <%- JSON.stringify(groupSlug) %>;

function escapeHtml(s) {
  return String(s||"").replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}

function fmtDate(iso) {
  if (!iso) return "";
  try {
    const d = new Date(iso);
    return d.toLocaleString(undefined, { month:"short", day:"numeric", year:"numeric", hour:"numeric", minute:"2-digit" });
  } catch(e) { return iso; }
}

function fmtDuration(seconds) {
  const s = Math.max(0, Math.round(Number(seconds) || 0));
  if (s < 60)    return s + "s";
  if (s < 3600)  return Math.floor(s/60) + "m " + (s%60) + "s";
  if (s < 86400) {
    const h = Math.floor(s/3600), m = Math.floor((s%3600)/60);
    return h + "h " + String(m).padStart(2,"0") + "m";
  }
  const d = Math.floor(s/86400), h = Math.floor((s%86400)/3600);
  return d + "d " + h + "h";
}

function renderIncident(inc) {
  const impact = inc.impact || "minor";
  const status = inc.status || (inc.ended_at ? "resolved" : "investigating");
  const isOpen = !inc.ended_at;
  const title  = inc.title || (inc.server_name + (inc.cause ? " — " + inc.cause.split(",")[0].trim() : ""));
  const updates = Array.isArray(inc.updates) ? inc.updates.slice().reverse() : [];
  const updatesHtml = updates.map(u => `
    <div class="update ${u.status}">
      <div class="update-head">
        <span class="update-status ${u.status}">${u.status}</span>
        <span class="update-time">${escapeHtml(fmtDate(u.created_at))}</span>
      </div>
      <div class="update-msg">${escapeHtml(u.message)}</div>
    </div>
  `).join("");
  const durationStr = inc.ended_at
    ? `<span><strong>Resolved in</strong> ${fmtDuration(inc.duration_s)}</span>`
    : `<span><strong>Ongoing</strong> since ${escapeHtml(fmtDate(inc.started_at))}</span>`;

  return `
    <div class="incident ${isOpen ? "open" : ""}">
      <div class="inc-head">
        <div class="inc-title">
          <h2>${escapeHtml(title)}</h2>
        </div>
        <div class="badges">
          <span class="badge status-${status}">${status}</span>
          <span class="badge impact-${impact}">${impact} impact</span>
        </div>
        <div class="inc-meta">
          <span><strong>Service:</strong> ${escapeHtml(inc.server_name)}</span>
          <span><strong>Started:</strong> ${escapeHtml(fmtDate(inc.started_at))}</span>
          ${durationStr}
        </div>
      </div>
      <div class="updates">${updatesHtml}</div>
    </div>
  `;
}

async function load() {
  try {
    const r = await fetch(`/api/public/group/${encodeURIComponent(GROUP_SLUG)}/incidents`);
    if (!r.ok) throw new Error("Failed to load");
    const data = await r.json();
    const openEl  = document.getElementById("openList");
    const openSec = document.getElementById("openSection");
    const recentEl = document.getElementById("recentList");

    if (data.open && data.open.length) {
      openEl.innerHTML = data.open.map(renderIncident).join("");
      openSec.style.display = "block";
    } else {
      openSec.style.display = "none";
    }

    if (data.recent && data.recent.length) {
      recentEl.innerHTML = data.recent.map(renderIncident).join("");
    } else {
      recentEl.innerHTML = `<div class="empty">No past incidents to show. All systems have been running smoothly. ✨</div>`;
    }
  } catch(e) {
    document.getElementById("recentList").innerHTML =
      `<div class="empty" style="color:var(--red)">Failed to load incident history. Please try again in a moment.</div>`;
  }
}

load();
</script>
</body>
</html>
