<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= type === 'privacy' ? 'Privacy Policy' : 'Terms of Service' %> — <%= g.name %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0a0a0a;--surface:#141414;--surface2:#1a1a1a;--border:rgba(255,255,255,0.06);--border-hi:rgba(255,255,255,0.10);--text:#a0a0a0;--text-2:#6f6f6f;--text-hi:#d4d4d4;--text-white:#f5f5f5;--shadow:rgba(0,0,0,0.5);--ga:rgba(255,140,42,0.10);--accent:<%- g.accent_color || '#ff8c2a' %>;--accent-soft:color-mix(in srgb,var(--accent) 12%,transparent);--sans:'Plus Jakarta Sans',sans-serif;--mono:'JetBrains Mono',monospace;--r:12px;--r-sm:8px}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;-webkit-font-smoothing:antialiased}
.bg-glow{position:fixed;inset:0;pointer-events:none;background:radial-gradient(ellipse 70% 60% at 50% 20%,var(--ga) 0%,transparent 70%)}
.wrap{position:relative;z-index:1;max-width:760px;margin:0 auto;padding:60px 24px 80px}
.back{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--text-2);text-decoration:none;margin-bottom:40px;transition:color .15s}
.back:hover{color:var(--text-hi)}
.brand{display:flex;align-items:center;gap:12px;margin-bottom:32px}
<% if (g.logo_image) { %>
.brand-logo{height:<%= Math.min(g.logo_size || 42, 56) %>px;width:auto;object-fit:contain}
<% } else { %>
.brand-icon{height:36px;min-width:36px;border-radius:9px;background:var(--accent-soft);border:1px solid color-mix(in srgb,var(--accent) 30%,transparent);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;color:var(--accent)}
<% } %>
.brand-name{font-size:18px;font-weight:700;color:var(--text-white);letter-spacing:-.02em}
h1{font-size:28px;font-weight:700;color:var(--text-white);letter-spacing:-.02em;margin-bottom:8px}
.meta{font-size:13px;color:var(--text-2);margin-bottom:40px}
.content{font-size:14px;line-height:1.8;color:var(--text);white-space:pre-wrap;word-break:break-word}
.content h1,.content h2,.content h3{color:var(--text-white);margin:28px 0 10px;font-weight:600}
.content h1{font-size:20px}.content h2{font-size:17px;padding-bottom:6px;border-bottom:1px solid var(--border)}.content h3{font-size:15px}
.content p{margin-bottom:12px}
.content ul,.content ol{margin:8px 0 12px 20px}
.content li{margin-bottom:4px}
.content a{color:var(--accent)}
.content strong{color:var(--text-hi);font-weight:600}
</style>
</head>
<body>
<div class="bg-glow"></div>
<div class="wrap">
  <a class="back" href="/dashboard/<%= g.slug %>">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    Back to <%= g.name %>
  </a>

  <div class="brand">
    <% if (g.logo_image) { %>
      <img class="brand-logo" src="<%= g.logo_image %>" alt="<%= g.name %>">
    <% } else { %>
      <div class="brand-icon"><%= (g.logo_text || g.name.charAt(0)).substring(0,2) %></div>
    <% } %>
    <div class="brand-name"><%= g.name %></div>
  </div>

  <h1><%= type === 'privacy' ? 'Privacy Policy' : 'Terms of Service' %></h1>
  <p class="meta"><%= g.name %></p>

  <div class="content"><%- content.replace(/</g, '&lt;').replace(/>/g, '&gt;') %></div>
</div>
<footer style="text-align:center;padding:24px 16px;font-size:12px;color:var(--text-2)">
  <a href="https://github.com/X4Applegate/status-server" target="_blank" rel="noopener" style="color:var(--text-2);text-decoration:none;display:inline-flex;align-items:center;gap:5px" onmouseover="this.style.color='var(--text-hi)'" onmouseout="this.style.color='var(--text-2)'"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.929.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.216.694.825.576C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>Applegate Monitor on GitHub</a>
</footer>
</body>
</html>
