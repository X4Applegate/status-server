// ── Groups (Dashboards) ──────────────────────────────────────────────────────
let adminGroups   = [];
let pendDelGroup  = null;
let pickedServers = new Set();   // selected server ids while editing a group

function slugifyJS(s){
  return String(s||"").toLowerCase().trim()
    .replace(/[^a-z0-9]+/g,"-")
    .replace(/^-|-$/g,"")
    .slice(0,64);
}

// Auto-fill slug when typing the name (only if user hasn't manually edited the slug)
let _slugDirty = false;
function autoSlug(name){
  if (_slugDirty) return;
  document.getElementById("gSlug").value = slugifyJS(name);
}

async function ensureGroupsLoaded(){
  if (adminGroups.length) return;
  const cached = cacheGet("admin-groups");
  if (cached) { adminGroups = cached; return; }
  try {
    const r = await fetch("/api/admin/groups");
    if (r.ok) { adminGroups = await r.json(); cacheSet("admin-groups", adminGroups); }
  } catch(e) { /* swallow */ }
}

function renderAdminGroupList(list){
