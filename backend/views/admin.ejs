async function switchTab(tab){
  // Viewers can access Servers, Omada, and Webhooks. Anything else (Groups/Users) bounces back.
  if (!isAdmin() && !["servers","omada","webhooks"].includes(tab)) tab = "servers";
  currentTab = tab;
  serverFormReturn = null;  // switching tabs clears any pending return target
  document.getElementById("tabServers").classList.toggle("active",  tab === "servers");
  document.getElementById("tabGroups").classList.toggle("active",   tab === "groups");
  document.getElementById("tabOmada").classList.toggle("active",    tab === "omada");
  document.getElementById("tabUsers").classList.toggle("active",    tab === "users");
  document.getElementById("tabWebhooks").classList.toggle("active", tab === "webhooks");
  const labels = { servers: "Add Server", groups: "Add Group", omada: "Add Controller", users: "Add User", webhooks: "Add Webhook" };
  document.getElementById("addBtnLabel").textContent  = labels[tab];
  document.getElementById("addBtn").onclick           =
    tab === "servers"  ? () => showServerForm(null) :
    tab === "groups"   ? () => showGroupForm(null)  :
    tab === "omada"    ? () => showOmadaForm(null)  :
    tab === "users"    ? () => showUserForm(null)   :
                         () => showWebhookForm(null);
  // Show list view, hide forms
  document.getElementById("aListView").style.display        = "flex";
  document.getElementById("aFormView").style.display        = "none";
  document.getElementById("aUserFormView").style.display    = "none";
  document.getElementById("aWebhookFormView").style.display = "none";
  document.getElementById("aGroupFormView").style.display   = "none";
  document.getElementById("aOmadaFormView").style.display   = "none";
  document.getElementById("aOmadaSitesView").style.display  = "none";
  // Load content
  if      (tab === "servers")  await loadServerList();
  else if (tab === "groups")   await loadGroupList();
  else if (tab === "omada")    await loadOmadaList();
  else if (tab === "users")    await loadUserList();
  else                         await loadWebhookList();
}

// ── Server list ───────────────────────────────────────────────────────────────
function renderAdminServerList(list){
  const el = document.getElementById("adminPanelBody");
  document.getElementById("aCount").textContent = `${list.length} server${list.length===1?"":"s"}`;
  if (!list.length){
    el.innerHTML = `<div class="empty-state">No servers yet.<br>Click <strong>Add Server</strong> to add one.</div>`;
    return;
  }
  el.innerHTML = list.map((s, idx) => {
    const checkSummary = (s.checks||[]).map(c =>
      c.type==="ping"?"Ping":
      c.type==="tcp"?`TCP :${c.port}`:
      c.type==="udp"?`UDP :${c.port}`:
      c.type==="dns"?`DNS ${(c.record_type||"A").toUpperCase()}`:
      c.type==="omada_gateway"?"Omada WAN":
      c.type==="omada_lte"?"Omada LTE":
      "HTTP"
    ).join(" - ") || "No checks";
    // Cert badges: pull from any HTTP check on this server that has live cert info
    const certBadges = (s.checks||[])
      .filter(c => c.type === "http" && c.cert && c.cert.expires_at)
      .map(c => {
        const d = c.cert.days_left;
        const ccls = d < 0 ? "cert-expired" : d < 14 ? "cert-warn" : "cert-ok";
        const txt  = d < 0 ? `SSL expired ${-d}d ago` : d < 1 ? "SSL expires today" : `SSL ${d}d`;
        const tt   = `${c.cert.subject || ""} · issued by ${c.cert.issuer || "?"} · expires ${new Date(c.cert.expires_at).toLocaleDateString()}`;
        return `<span class="chip-cert ${ccls}" title="${tt.replace(/"/g,"&quot;")}">${txt}</span>`;
      }).join("");
    return `<div class="admin-server-item" onclick="showServerForm(adminServers[${idx}])">
      <div class="admin-dot ${s.overall||'pending'}"></div>
      <div class="admin-info">
        <div class="admin-name">${s.name}</div>
        <div class="admin-host">${s.host}</div>
        <div class="admin-checks-label">${checkSummary}${certBadges ? " " + certBadges : ""}</div>
      </div>
      <div class="admin-row-actions" onclick="event.stopPropagation()">
        <button class="btn btn-sm" onclick="showServerForm(adminServers[${idx}])">Edit</button>
        ${isAdmin() ? `<button class="btn btn-sm btn-danger" onclick="askDel('${s.id}','${s.name}')">Remove</button>` : ``}
      </div>
    </div>`;
  }).join("");
}

async function loadServerList(){
  const el = document.getElementById("adminPanelBody");

  // 1) Instant render from cache
  const cached = cacheGet("admin-servers");
  if (cached) {
    adminServers = cached;
    renderAdminServerList(adminServers);
  } else {
    el.innerHTML = `<div style="padding:24px;text-align:center;color:var(--text-2)">Loading servers...</div>`;
  }

  // 2) Fetch fresh
  try {
    const r = await fetch("/api/admin/servers");
    if (r.status === 401) { window.location.href = "/"; return; }
    if (!r.ok) {
      if (!cached) el.innerHTML = `<div class="empty-state">Error ${r.status}</div>`;
      return;
    }
    adminServers = await r.json();
    cacheSet("admin-servers", adminServers);
    renderAdminServerList(adminServers);
    return;
  } catch(e) {
    if (!cached) el.innerHTML = `<div class="empty-state">Failed to load: ${e.message}</div>`;
  }
}

