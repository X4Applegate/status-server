  el.innerHTML = list.map((c, idx) => {
    const modeBadge = c.mode === "msp" ? ` <span style="font-size:9px;font-weight:600;padding:1px 6px;border-radius:8px;background:var(--blue-soft);color:var(--blue);letter-spacing:.04em;vertical-align:middle">MSP</span>` : "";
    const errorBadge = c.last_error ? `<div class="admin-checks-label" style="color:var(--red)">⚠ ${c.last_error}</div>` : `<div class="admin-checks-label">omadacId: <span style="font-family:var(--mono)">${(c.omadac_id||"—").slice(0,16)}…</span></div>`;
    return `<div class="admin-server-item" onclick="showOmadaSites(adminOmada[${idx}])">
      <div class="admin-dot ${c.last_error ? 'down' : 'up'}"></div>
      <div class="admin-info">
        <div class="admin-name">${c.name}${modeBadge}</div>
        <div class="admin-host">${c.base_url}</div>
        ${errorBadge}
      </div>
      <div class="admin-row-actions" onclick="event.stopPropagation()">
        <button class="btn btn-sm" onclick="showOmadaSites(adminOmada[${idx}])">Sites</button>
        <button class="btn btn-sm" onclick="showOmadaForm(adminOmada[${idx}])">Edit</button>
        <button class="btn btn-sm btn-danger" onclick="askDelOmada(${c.id},'${c.name.replace(/'/g,"\\'")}')">Remove</button>
      </div>
    </div>`;
  }).join("");
}

async function loadOmadaList(){
  const el = document.getElementById("adminPanelBody");
  const cached = cacheGet("admin-omada");
  if (cached) { adminOmada = cached; renderAdminOmadaList(adminOmada); }
  else el.innerHTML = `<div style="padding:24px;text-align:center;color:var(--text-2)">Loading controllers...</div>`;
  try {
    const r = await fetch("/api/admin/omada-controllers");
    if (r.status === 401) { window.location.href = "/"; return; }
    if (!r.ok) { if (!cached) el.innerHTML = `<div class="empty-state">Error ${r.status}</div>`; return; }
    adminOmada = await r.json();
    cacheSet("admin-omada", adminOmada);
    renderAdminOmadaList(adminOmada);
  } catch(e) {
    if (!cached) el.innerHTML = `<div class="empty-state">Failed to load: ${e.message}</div>`;
  }
}

async function showOmadaForm(c){
  document.getElementById("aListView").style.display        = "none";
  document.getElementById("aFormView").style.display        = "none";
  document.getElementById("aUserFormView").style.display    = "none";
  document.getElementById("aWebhookFormView").style.display = "none";
  document.getElementById("aGroupFormView").style.display   = "none";
  document.getElementById("aOmadaSitesView").style.display  = "none";
  document.getElementById("aOmadaFormView").style.display   = "flex";
  document.getElementById("oFormHeading").textContent  = c ? "Edit Omada Controller" : "Add Omada Controller";
  document.getElementById("oId").value           = c?.id        || "";
  document.getElementById("oName").value         = c?.name      || "";
  document.getElementById("oUrl").value          = c?.base_url  || "";
  document.getElementById("oClientId").value     = c?.client_id || "";
  document.getElementById("oClientSecret").value = "";  // never round-trip the secret
  document.getElementById("oVerifyTls").checked  = c ? !!c.verify_tls : true;
  document.getElementById("oSecretHint").textContent = c ? "(leave blank to keep existing)" : "*";
  document.getElementById("oErr").textContent = "";
  // Populate the Owner Group dropdown — admin can pick "Global" (no group), viewers must pick one of theirs
  await ensureGroupsLoaded();
  const sel = document.getElementById("oGroup");
  if (isAdmin()) {
    sel.innerHTML = `<option value="">— Global (admin only) —</option>` +
      adminGroups.map(g => `<option value="${g.id}" ${c && c.group_id == g.id ? "selected" : ""}>${g.name}</option>`).join("");
  } else {
    const defaultId = (c && c.group_id) || (adminGroups[0] && adminGroups[0].id) || "";
    sel.innerHTML = adminGroups.map(g => `<option value="${g.id}" ${defaultId == g.id ? "selected" : ""}>${g.name}</option>`).join("");
  }
}

async function submitOmadaForm(){
  const name          = document.getElementById("oName").value.trim();
  const base_url      = document.getElementById("oUrl").value.trim();
  const client_id     = document.getElementById("oClientId").value.trim();
  const client_secret = document.getElementById("oClientSecret").value;
  const verify_tls    = document.getElementById("oVerifyTls").checked;
  const groupSel      = document.getElementById("oGroup").value;
  const id            = document.getElementById("oId").value;
  if (!name || !base_url || !client_id) {
    document.getElementById("oErr").textContent = "Name, URL and Client ID are required.";
    return;
  }
  if (!id && !client_secret) {
    document.getElementById("oErr").textContent = "Client Secret is required for new controllers.";
    return;
  }
  document.getElementById("oErr").textContent = "Contacting controller…";
  try {
    const r = await fetch(id ? `/api/admin/omada-controllers/${id}` : "/api/admin/omada-controllers", {
      method: id ? "PUT" : "POST",
      headers: {"Content-Type":"application/json"},
      body: JSON.stringify({ name, base_url, client_id, client_secret, verify_tls, group_id: groupSel ? parseInt(groupSel) : null })
    });
    const d = await r.json();
    if (!r.ok) { document.getElementById("oErr").textContent = d.error || "Failed"; return; }
    cacheDel("admin-omada");
    if (d.warning) toast(d.warning, "info"); else toast(id ? "Controller updated" : "Controller added", "success");
    showList();
  } catch(e) {
    document.getElementById("oErr").textContent = "Error: " + e.message;
  }
}

function askDelOmada(id, name){
  pendDelOmada = id;
  document.getElementById("confirmMsg").textContent = `Omada controller "${name}" will be removed. Servers using it will fail their checks until reconfigured.`;
  document.getElementById("confirmDlg").classList.add("open");
  document.querySelector("#confirmDlg .btn-danger").onclick = doDeleteOmada;
}

async function doDeleteOmada(){
  if (!pendDelOmada) return;
  try {
    const r = await fetch(`/api/admin/omada-controllers/${pendDelOmada}`, {method:"DELETE"});
    const d = await r.json();
    if (r.ok) cacheDel("admin-omada");
    toast(r.ok ? "Controller removed" : (d.error||"Failed"), r.ok ? "info" : "error");
  } catch(e) { toast("Error: " + e.message, "error"); }
  pendDelOmada = null;
  closeConfirm();
  loadOmadaList();
}

async function showOmadaSites(c){
  document.getElementById("aListView").style.display        = "none";
  document.getElementById("aFormView").style.display        = "none";
  document.getElementById("aUserFormView").style.display    = "none";
  document.getElementById("aWebhookFormView").style.display = "none";
  document.getElementById("aGroupFormView").style.display   = "none";
  document.getElementById("aOmadaFormView").style.display   = "none";
  document.getElementById("aOmadaSitesView").style.display  = "flex";
  const modeBadge = c.mode === "msp" ? ' <span style="font-size:9px;font-weight:600;padding:1px 6px;border-radius:8px;background:var(--blue-soft);color:var(--blue);letter-spacing:.04em;vertical-align:middle">MSP</span>' : "";
  document.getElementById("oSitesHeading").innerHTML = `Sites — ${c.name}${modeBadge}`;
  document.getElementById("oSitesSubhead").textContent = c.base_url;
  const list = document.getElementById("oSitesList");
  list.innerHTML = `<div style="padding:18px;text-align:center;color:var(--text-2);font-size:12px">Fetching sites from controller…</div>`;
  try {
    const r = await fetch(`/api/admin/omada-controllers/${c.id}/sites`);
    if (!r.ok) {
      const d = await r.json().catch(()=>({error:"unknown"}));
      list.innerHTML = `<div style="padding:18px;text-align:center;color:var(--red);font-size:12px">${d.error || ("HTTP "+r.status)}</div>`;
      return;
    }
    const sites = await r.json();
    omadaSitesCache[c.id] = sites;
    if (!sites.length) {
      list.innerHTML = `<div style="padding:18px;text-align:center;color:var(--text-2);font-size:12px">No sites returned by this controller.</div>`;
      return;
    }
    // Build a row helper that includes customer_id and the friendly names when present
    const esc = (v) => String(v||"").replace(/'/g,"\\'");
    const renderSiteRow = (s) => {
      const sid    = s.siteId || s.id;
      const sname  = s.name || sid;
      const cid    = s.customerId || "";
      const cname  = s.customerName || "";
      const args   = `${c.id}, '${esc(sid)}', '${esc(sname)}', '${esc(cid)}', '${esc(cname)}'`;
      return `<div style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r-sm)">
        <div style="flex:1;min-width:0">
          <div style="font-size:13px;font-weight:500;color:var(--text-hi)">${sname}</div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--text-2);margin-top:2px">${sid}</div>
        </div>
        <button class="btn btn-sm btn-primary" onclick="createServerFromSite(${args})">+ Create server</button>
      </div>`;
    };
    if (c.mode === "msp") {
      // Group sites by customer
      const byCust = {};
      sites.forEach(s => {
        const key = s.customerId || "unknown";
        if (!byCust[key]) byCust[key] = { name: s.customerName || key, items: [] };
        byCust[key].items.push(s);
      });
      list.innerHTML = Object.entries(byCust).map(([cid, group]) => `
        <div style="margin-top:8px">
          <div style="font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-2);padding:4px 0 8px">${group.name}</div>
          <div style="display:flex;flex-direction:column;gap:6px">${group.items.map(renderSiteRow).join("")}</div>
        </div>
      `).join("");
    } else {
      list.innerHTML = sites.map(renderSiteRow).join("");
    }
  } catch(e) {
    list.innerHTML = `<div style="padding:18px;text-align:center;color:var(--red);font-size:12px">${e.message}</div>`;
  }
}

// Where to bounce back to after the server form closes — used by createServerFromSite
// to return the admin to the Omada sites browser instead of the Servers tab.
let serverFormReturn = null;

// One-click: jump to the server form pre-filled with an omada_gateway check
async function createServerFromSite(controllerId, siteId, siteName, customerId, customerName){
  await showServerForm(null);
  // Set the return target AFTER showServerForm so it doesn't get cleared by edit/add flows
  serverFormReturn = { type: "omada-sites", controller: adminOmada.find(c => c.id === controllerId) };
  document.getElementById("fName").value = siteName;
  document.getElementById("fHost").value = "omada-managed";  // host is unused for omada checks but required by validation
  // Replace the default ping check with an omada_gateway check.
  // We store BOTH the IDs and the friendly names — the names are required to filter
  // /devices/known-devices (which doesn't return siteId per device).
  const check = { type: "omada_gateway", controller_id: controllerId, site_id: siteId, site_name: siteName };
  if (customerId)   check.customer_id   = customerId;
  if (customerName) check.customer_name = customerName;
  currentChecks = [check];
  renderCrows();
}

// ── Toast ─────────────────────────────────────────────────────────────────────
function toast(msg, type="info"){
  const s  = document.getElementById("toasts");
  const el = document.createElement("div");
  el.className   = `toast ${type}`;
  el.textContent = msg;
  s.appendChild(el);
  setTimeout(() => el.remove(), 3000);
}


</script>
</body>
</html>