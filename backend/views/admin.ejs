// Render the chosen/existing logo image inside the small 48x48 preview tile
function renderGroupLogoPreview(dataUrl){
  const box = document.getElementById("gLogoPreview");
  const clr = document.getElementById("gLogoClearBtn");
  if (dataUrl) {
    box.innerHTML = `<img src="${dataUrl}" alt="logo" style="width:100%;height:100%;object-fit:contain;border-radius:6px">`;
    clr.style.display = "inline-flex";
  } else {
    box.innerHTML = "none";
    clr.style.display = "none";
  }
}

// File picker handler — reads the image as base64 and stores it on the hidden field
function onGroupLogoFile(e){
  const file = e.target.files && e.target.files[0];
  if (!file) return;
  if (file.size > 256 * 1024) {
    document.getElementById("gErr").textContent = `Image too large (${Math.round(file.size/1024)} KB; max 256 KB). Please resize first.`;
    e.target.value = "";
    return;
  }
  document.getElementById("gErr").textContent = "";
  const reader = new FileReader();
  reader.onload = () => {
    const dataUrl = reader.result;
    document.getElementById("gLogoImageData").value = dataUrl;
    renderGroupLogoPreview(dataUrl);
  };
  reader.onerror = () => {
    document.getElementById("gErr").textContent = "Failed to read image file.";
  };
  reader.readAsDataURL(file);
}

function clearGroupLogo(){
  document.getElementById("gLogoImageData").value = "";
  document.getElementById("gLogoFile").value = "";
  renderGroupLogoPreview("");
}

