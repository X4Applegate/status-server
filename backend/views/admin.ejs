// ── localStorage cache helpers (stale-while-revalidate) ──────────────────────
const CACHE_PREFIX = "sm-cache-";
function cacheGet(key){
  try { const v = localStorage.getItem(CACHE_PREFIX + key); return v ? JSON.parse(v) : null; }
  catch(e){ return null; }
}
function cacheSet(key, val){
  try { localStorage.setItem(CACHE_PREFIX + key, JSON.stringify(val)); } catch(e){}
}
function cacheDel(key){
  try { localStorage.removeItem(CACHE_PREFIX + key); } catch(e){}
}
function cacheClearAdmin(){
  try {
    Object.keys(localStorage)
      .filter(k => k.startsWith(CACHE_PREFIX + "admin-"))
      .forEach(k => localStorage.removeItem(k));
  } catch(e){}
}

async function doLogout(){
  await fetch("/api/logout", {method:"POST"});
  // Clear admin caches so the next user doesn't see the previous admin's data
  cacheClearAdmin();
  window.location.href = "/";
}

// ── Change Password ───────────────────────────────────────────────────────────
function openChangePassword(){
  document.getElementById("changePwdModal").classList.add("open");
  ["pwdCurrent","pwdNew","pwdConfirm"].forEach(id => document.getElementById(id).value = "");
  document.getElementById("pwdErr").textContent = "";
}
function closeChangePassword(){
  document.getElementById("changePwdModal").classList.remove("open");
}
async function submitChangePassword(){
  const cur = document.getElementById("pwdCurrent").value;
  const nw  = document.getElementById("pwdNew").value;
  const cf  = document.getElementById("pwdConfirm").value;
  const err = document.getElementById("pwdErr");
  if (!cur || !nw || !cf)  { err.textContent = "All fields required"; return; }
  if (nw !== cf)            { err.textContent = "Passwords do not match"; return; }
  if (nw.length < 8)        { err.textContent = "Min 8 characters"; return; }
  try {
    const r = await fetch("/api/change-password", {
      method:"POST", headers:{"Content-Type":"application/json"},
      body: JSON.stringify({currentPassword:cur, newPassword:nw})
    });
    const d = await r.json();
    if (!r.ok) { err.textContent = d.error || "Failed"; return; }
    closeChangePassword();
    toast("Password updated", "success");
  } catch(e) { err.textContent = "Error: " + e.message; }
}

// ── Drawer management ─────────────────────────────────────────────────────────
let activeDrawer = null;
function openDrawer(id){
  if (activeDrawer && activeDrawer !== id) document.getElementById(activeDrawer).classList.remove("open");
  activeDrawer = id;
  document.getElementById(id).classList.add("open");
  document.getElementById("sharedOverlay").classList.add("open");
  document.body.style.overflow = "hidden";
}
function closeDrawer(id){
  document.getElementById(id)?.classList.remove("open");
  document.getElementById("sharedOverlay").classList.remove("open");
