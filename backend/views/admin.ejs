        <button class="btn btn-sm btn-danger" onclick="askDelGroup(${g.id},'${g.name.replace(/'/g,"\\'")}')">Remove</button>
      </div>
    </div>
  `).join("");
}

async function loadGroupList(){
  const el = document.getElementById("adminPanelBody");
  const cached = cacheGet("admin-groups");
