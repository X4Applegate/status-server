  const cached = cacheGet("admin-webhooks");
  if (cached) renderAdminWebhookList(cached);
  else        el.innerHTML = `<div style="padding:24px;text-align:center;color:var(--text-2)">Loading webhooks...</div>`;

  // 2) Fetch fresh
  try {
    const r = await fetch("/api/admin/webhooks");
    if (r.status === 401){ window.location.href = "/"; return; }
    if (r.status === 403){
      if (!cached) el.innerHTML = `<div class="empty-state">Admin role required.</div>`;
      return;
    }
    if (!r.ok){
      if (!cached) el.innerHTML = `<div class="empty-state">Error ${r.status}</div>`;
      return;
    }
    const hooks = await r.json();
    cacheSet("admin-webhooks", hooks);
    renderAdminWebhookList(hooks);
  } catch(e){
    if (!cached) el.innerHTML = `<div class="empty-state">Failed: ${e.message}</div>`;
  }
