  pickedServers = new Set(g?.server_ids || []);
  // View link only on edit
  const link = document.getElementById("gViewLink");
  if (g) { link.href = `/dashboard/${g.slug}`; link.textContent = `View /dashboard/${g.slug} →`; link.style.display = "inline"; }
  else   { link.style.display = "none"; }
