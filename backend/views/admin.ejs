// ── Webhook list ──────────────────────────────────────────────────────────────
let _webhookStore = {};
let pendDelWebhook = null;

function renderAdminWebhookList(hooks){
  const el = document.getElementById("adminPanelBody");
  _webhookStore = {};
  hooks.forEach(h => _webhookStore[h.id] = h);
  document.getElementById("aCount").textContent = `${hooks.length} webhook${hooks.length===1?"":"s"}`;
  if (!hooks.length){
    el.innerHTML = `<div class="empty-state">No webhooks yet.<br>Click <strong>Add Webhook</strong> to send alerts when servers go down.</div>`;
    return;
  }
  el.innerHTML = hooks.map(h => {
    const triggers = [h.fire_on_down ? "down" : null, h.fire_on_recovery ? "recovery" : null].filter(Boolean).join(" - ") || "none";
    const status   = h.enabled ? "" : ' <span style="color:var(--text-2);font-size:10px">(disabled)</span>';
    const fmt      = h.format === "auto" ? "auto" : h.format;
    return `<div class="admin-server-item" onclick="showWebhookForm(_webhookStore[${h.id}])">
      <div class="admin-dot ${h.enabled?'up':'pending'}"></div>
      <div class="admin-info">
        <div class="admin-name">${h.name}${status}</div>
        <div class="admin-host">${h.url.length > 60 ? h.url.slice(0, 60) + "..." : h.url}</div>
        <div class="admin-checks-label">${fmt} - fires on: ${triggers}</div>
      </div>
      <div class="admin-row-actions" onclick="event.stopPropagation()">
        <button class="btn btn-sm" onclick="testWebhook(${h.id})">Test</button>
        <button class="btn btn-sm" onclick="showWebhookForm(_webhookStore[${h.id}])">Edit</button>
        <button class="btn btn-sm btn-danger" onclick="askDelWebhook(${h.id})">Remove</button>
      </div>
    </div>`;
  }).join("");
}

async function loadWebhookList(){
  const el = document.getElementById("adminPanelBody");

