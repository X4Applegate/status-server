function toggleUserGroup(id, on){
  if (on) userPickedGroups.add(id); else userPickedGroups.delete(id);
}

function showUserList(){ showList(); }

async function submitUserForm(){
  const id       = document.getElementById("uId").value;
  const username = document.getElementById("uName").value.trim();
  const role     = document.getElementById("uRole").value;
  const password = document.getElementById("uPassword").value;
  const err      = document.getElementById("uErr");
  if (!username)           { err.textContent = "Username required"; return; }
  if (!id && !password)    { err.textContent = "Password required for new users"; return; }
  const body = {username, role};
  if (password) body.password = password;
  // Only attach allowed_group_ids when role=viewer (admins are always unrestricted)
  if (role === "viewer") body.allowed_group_ids = Array.from(userPickedGroups);
  try {
    const r = await fetch(id ? `/api/admin/users/${id}` : "/api/admin/users", {
      method: id ? "PUT" : "POST",
      headers:{"Content-Type":"application/json"},
      body: JSON.stringify(body)
    });
    const d = await r.json();
    if (!r.ok){ err.textContent = d.error || "Failed"; return; }
    cacheDel("admin-users");
    toast(id ? "User updated" : "User created", "success");
    showList();
  } catch(e){ err.textContent = "Error: " + e.message; }
}

