let serverPickedGroups = new Set();   // currently-checked group ids in the server form

async function showServerForm(s){
  document.getElementById("aListView").style.display       = "none";
  document.getElementById("aFormView").style.display       = "flex";
  document.getElementById("aUserFormView").style.display   = "none";
  document.getElementById("aGroupFormView").style.display  = "none";
  document.getElementById("aOmadaFormView").style.display  = "none";
  document.getElementById("aOmadaSitesView").style.display = "none";
  document.getElementById("fHeading").textContent = s ? "Edit Server" : "Add Server";
  document.getElementById("fId").value    = s?.id || "";
  document.getElementById("fName").value  = s?.name || "";
  document.getElementById("fHost").value  = s?.host || "";
  document.getElementById("fDesc").value  = s?.description || "";
  document.getElementById("fTags").value  = (s?.tags||[]).join(", ");
  document.getElementById("fInterval").value = String(s?.poll_interval_sec || 30);
  document.getElementById("fErr").textContent = "";
  currentChecks = (s?.checks||[{type:"ping"}]).map(c => ({...c}));
  // Initialize group selection from the server's existing group_ids
  serverPickedGroups = new Set(s?.group_ids || []);
  // If creating a new server as a viewer, default-check their first allowed group
  if (!s && !isAdmin()) {
    await ensureGroupsLoaded();
    if (adminGroups.length && serverPickedGroups.size === 0) {
      serverPickedGroups.add(adminGroups[0].id);
    }
  }
  // Load groups + omada controllers in parallel before rendering check rows
  await Promise.all([ensureGroupsLoaded(), ensureOmadaLoaded()]);
  renderCrows();
  renderServerGroupsPicker();
  renderBadgeSection(s);
}

function renderServerGroupsPicker(){
