async function showGroupForm(g){
  document.getElementById("aListView").style.display        = "none";
  document.getElementById("aFormView").style.display        = "none";
  document.getElementById("aUserFormView").style.display    = "none";
  document.getElementById("aWebhookFormView").style.display = "none";
  document.getElementById("aGroupFormView").style.display   = "flex";
  document.getElementById("gFormHeading").textContent = g ? "Edit Group" : "Add Group";
  document.getElementById("gId").value    = g?.id    || "";
  document.getElementById("gName").value  = g?.name  || "";
  document.getElementById("gSlug").value  = g?.slug  || "";
  document.getElementById("gDesc").value  = g?.description || "";
  document.getElementById("gLogo").value  = g?.logo_text   || "";
  document.getElementById("gColor").value = g?.accent_color || "#2a7fff";
  const lsz = g?.logo_size || 42;
  document.getElementById("gLogoSize").value = lsz;
  document.getElementById("gLogoSizeVal").textContent = lsz + "px";
  document.getElementById("gTheme").value = g?.default_theme || "dark";
  document.getElementById("gCustomDomain").value = g?.custom_domain || "";
