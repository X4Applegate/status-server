<script>

// ── Server detail view state ─────────────────────────────────────────────────
let selectedServerId = null;
let liveServers      = []; // latest snapshot from SSE / cache

// -- Helpers
function fmtDur(secs){
  if (!secs) return "ongoing";
  if (secs < 60)   return `${secs}s`;
  if (secs < 3600) return `${Math.floor(secs/60)}m ${secs%60}s`;
  return `${Math.floor(secs/3600)}h ${Math.floor((secs%3600)/60)}m`;
}
function fmtTime(ts){
  return new Date(ts).toLocaleString("en-US",{month:"short",day:"numeric",hour:"2-digit",minute:"2-digit",hour12:false});
}
function uptimeCls(pct){
  if (pct === null || pct === undefined) return "";
  if (pct >= 99) return "great";
  if (pct >= 95) return "good";
  if (pct >= 80) return "warn";
  return "bad";
}

// ── Theme ─────────────────────────────────────────────────────────────────────
const html = document.documentElement;
html.setAttribute("data-theme", localStorage.getItem("sm-theme") || "dark");
function toggleTheme(){
  const n = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
  html.setAttribute("data-theme", n);
  localStorage.setItem("sm-theme", n);
}

// ── Clock ─────────────────────────────────────────────────────────────────────
setInterval(() => {
  document.getElementById("clock").textContent = new Date().toLocaleTimeString("en-US", {hour12:false});
}, 1000);

// ── Session / Auth ────────────────────────────────────────────────────────────
let sessionRole = "";
let sessionAllowedGroupIds = null;   // null = unrestricted (admin), array = viewer's allowed groups
function isAdmin(){ return sessionRole === "admin"; }
function isViewer(){ return sessionRole === "viewer"; }

(async function initSession(){
  try {
    const r = await fetch("/api/me");
    // Guard: if response is not JSON, treat as logged out (not an error)
    const ct = r.headers.get("content-type") || "";
    if (!ct.includes("application/json")) {
      document.getElementById("loginBtn").style.display = "";
      return;
    }
    const d = await r.json();
    if (d.loggedIn) {
      sessionRole = d.role || "viewer";
      sessionAllowedGroupIds = d.allowed_group_ids || null;
      const show = ids => ids.forEach(id => { const el=document.getElementById(id); if(el) el.style.display=""; });
      // Both roles get badge, logout, change-password, refresh, AND the Admin button
      // (viewers need it to manage servers in their assigned groups)
      show(["userBadge","logoutBtn","pwdBtn","rfBtn","adminMenuBtn"]);
      // Logs are system-info — admin only
      if (isAdmin()) show(["logMenuBtn"]);
      const badge = document.getElementById("userBadge");
      if (badge) badge.textContent = d.username;
      applyRoleVisibility();
      // Populate the topbar dashboard quick-nav with the user's accessible dashboards
      renderTopbarDashboards();
      // If the page was opened with ?edit=<server_id>, auto-open the admin drawer + server form.
      // This powers the inline Edit buttons on the status page sidebar.
      const editId = new URLSearchParams(window.location.search).get("edit");
      if (editId) {
        setTimeout(() => autoOpenServerEdit(editId), 0);
      }
      // If opened with ?newGroup=1 (from the sidebar "+ New Dashboard" shortcut on /),
      // auto-open the Groups tab with a blank Add Group form.
      const newGroup = new URLSearchParams(window.location.search).get("newGroup");
      if (newGroup) {
        setTimeout(() => autoOpenNewGroup(), 0);
      }
    } else {
      document.getElementById("loginBtn").style.display = "";
    }
  } catch(e) {
    console.warn("Session check failed:", e.message);
    const loginBtn = document.getElementById("loginBtn");
    if (loginBtn) loginBtn.style.display = "";
  }
})();

// Hide admin-only tabs from viewers. Called once when session is established.
// Viewers can use Servers, Omada, and Webhooks (scoped to their groups).
// Groups + Users tabs stay admin-only.
function applyRoleVisibility(){
  if (isAdmin()) return;  // admins see everything; nothing to hide
  ["tabGroups","tabUsers"].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.style.display = "none";
  });
}

// Fetch the user's accessible dashboards and render them as clickable buttons in the topbar.
// /api/admin/groups is already filtered by role — admin sees all, viewer sees only their own.
// Admins also get a trailing "Admin" pill that links to the master view at `/`; viewers
// see the same pill but clicking it pops a permission-denied toast (matches public page behavior).
async function renderTopbarDashboards(){
  const el = document.getElementById("topbarDashboards");
  if (!el) return;
  try {
    const r = await fetch("/api/admin/groups");
    if (!r.ok) return;
    const groups = await r.json();
    const pills = groups.map(g => {
      const dot = g.accent_color || "var(--blue)";
      return `<a class="dash-nav" href="/dashboard/${g.slug}" title="Open ${g.name}">
        <span class="dash-nav-dot" style="background:${dot}"></span>
        ${g.name}
      </a>`;
    });
    // Admin pill — only shown to admins (links to the master dashboard "/" which viewers can't access).
    // Viewers don't get a pill here because they're already on /admin; adding one would be redundant.
    if (isAdmin()) {
      pills.push(`<a class="dash-nav dash-nav-admin" href="/" title="Admin master view — all servers">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 7h7l-5.5 4 2 7-6.5-4.5L5.5 20l2-7L2 9h7z"/></svg>
        Admin
      </a>`);
    }
    el.innerHTML = pills.join("");
  } catch(e) { /* silent */ }
}

// Auto-open the admin drawer with a specific server pre-filled for editing.
// Used when /admin is opened with ?edit=<server_id> (from the sidebar edit button).
async function autoOpenServerEdit(serverId){
  try {
    openDrawer("adminDrawer");
    await switchTab("servers");
    // loadServerList populates adminServers — find the matching one and open the form
    const match = adminServers.find(s => s.id === serverId);
