  activeDrawer = null;
}
function closeAll(){ if (activeDrawer) closeDrawer(activeDrawer); }

// ── Log Drawer ────────────────────────────────────────────────────────────────
let logEntries = [], logFilter = "all", autoScroll = true, unread = 0;

function openLogs(){
  unread = 0;
  document.getElementById("logBadge").classList.remove("show");
  openDrawer("logDrawer");
  renderLogs();
}
function closeLogs(){ closeDrawer("logDrawer"); }
function setLF(f, el){
  logFilter = f;
  document.querySelectorAll(".filter-tab").forEach(t => t.classList.remove("active"));
  el.classList.add("active");
  renderLogs();
}
function toggleAS(){
  autoScroll = !autoScroll;
  document.getElementById("asTrk").classList.toggle("on", autoScroll);
}
function clearLogs(){ logEntries = []; renderLogs(); }

function addLog(e){
  logEntries.unshift(e);
  if (logEntries.length > 300) logEntries.pop();
  if (activeDrawer !== "logDrawer"){
    unread++;
    const b = document.getElementById("logBadge");
    b.textContent = unread > 99 ? "99+" : unread;
    b.classList.add("show");
  }
  if (activeDrawer === "logDrawer") renderLogs();
}

function renderLogs(){
  const body = document.getElementById("logBody");
  let list = [...logEntries];
  if (logFilter === "error")   list = list.filter(l => l.level === "error");
  if (logFilter === "changes") list = list.filter(l => l.isStatusChange);
  document.getElementById("logCount").textContent = `${list.length} entr${list.length === 1 ? "y" : "ies"}`;
  if (!list.length){
    body.innerHTML = `<div class="log-empty"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>${logFilter === "all" ? "Waiting for results..." : "No matching entries"}</div>`;
    return;
  }
  const fmt = ts => new Date(ts).toLocaleTimeString("en-US", {hour12:false, hour:"2-digit", minute:"2-digit", second:"2-digit"});
  body.innerHTML = list.map((e, i) => {
    let cls = "log-entry", ic = "o";
    if (e.isStatusChange)      { cls += " change"; ic = ">"; }
    else if (e.level === "error") { cls += " fail";   ic = "x"; }
    else if (e.server === "system") { cls += " sys";  ic = "*"; }
    else                          { cls += " ok";     ic = "+"; }
    if (i === 0) cls += " new-entry";
    return `<div class="${cls}"><span class="log-ts">${fmt(e.ts)}</span><span class="log-icon">${ic}</span><span class="log-server">${e.server||"system"}</span><span class="log-msg">${e.message||e.msg||""}</span></div>`;
  }).join("");
  if (autoScroll) body.scrollTop = 0;
}

// ── Status stream + sidebar/stats ────────────────────────────────────────────
function renderServers(servers){
  liveServers = servers;
  cacheSet("servers", servers);

  // Sidebar list
  const sidebar = document.getElementById("sidebarList");
  if (sidebar) {
    sidebar.innerHTML = servers.map(s => {
      const lbl    = s.overall==="up"?"UP":s.overall==="down"?"DOWN":s.overall==="degraded"?"DEG":"PEND";
      const active = s.id === selectedServerId ? " active" : "";
      return `<div class="srv-row${active}" onclick="selectServer('${s.id}')">
        <div class="srv-dot ${s.overall||'pending'}"></div>
        <div class="srv-row-info">
          <div class="srv-row-name">${s.name}</div>
          <div class="srv-row-host">${s.host}</div>
        </div>
        <div class="srv-badge ${s.overall||'pending'}">${lbl}</div>
      </div>`;
    }).join("");
  }

  // Stats
  document.getElementById("sT").textContent = servers.length;
  document.getElementById("sU").textContent = servers.filter(s => s.overall === "up").length;
  document.getElementById("sD").textContent = servers.filter(s => s.overall === "down").length;
  document.getElementById("sW").textContent = servers.filter(s => s.overall === "degraded").length;
  document.getElementById("footTs").textContent = `Last check: ${new Date().toLocaleTimeString()}`;

  // Auto-select first server on first paint
  if (!selectedServerId && servers.length > 0) {
    const cachedSelected = cacheGet("selected-id");
    const initialId = cachedSelected && servers.find(s => s.id === cachedSelected) ? cachedSelected : servers[0].id;
    selectServer(initialId);
    return;
  }

  // If currently-selected server's status changed, refresh the small status badge in detail view
  if (selectedServerId) {
    const s = servers.find(x => x.id === selectedServerId);
    if (s) {
      const big = document.querySelector("#mainArea .status-big");
      if (big) {
        big.className = `status-big ${s.overall||"pending"}`;
        const lbl = big.querySelector(".status-big-label");
        if (lbl) lbl.textContent = s.overall==="up"?"Online":s.overall==="down"?"Offline":s.overall==="degraded"?"Degraded":"Pending";
        const tm = big.querySelector(".status-big-time");
        if (tm) tm.textContent = s.lastChecked ? `Last checked ${new Date(s.lastChecked).toLocaleTimeString()}` : "Not yet checked";
      }
    }
  }
}

// ── Server detail (cached, stale-while-revalidate) ───────────────────────────
async function selectServer(id){
  selectedServerId = id;
  cacheSet("selected-id", id);

  // Mark active row in sidebar
  document.querySelectorAll(".srv-row").forEach(r => r.classList.remove("active"));
  const rows = document.querySelectorAll(".srv-row");
  rows.forEach(r => {
    if (r.getAttribute("onclick") && r.getAttribute("onclick").includes("'" + id + "'")) r.classList.add("active");
  });

  const server = liveServers.find(s => s.id === id);
  if (!server) return;

  // 1) Render from cache instantly
  const cached = cacheGet("detail-" + id);
  if (cached) renderDetail(server, cached.uptime, cached.heartbeat, cached.incidents);
  else        renderDetailSkeleton(server);

  // 2) Fetch fresh in parallel
  const [uptime, heartbeat, incidents] = await Promise.all([
    fetch(`/api/public/uptime/${id}`).then(r=>r.json()).catch(()=>({})),
    fetch(`/api/public/heartbeat/${id}`).then(r=>r.json()).catch(()=>[]),
    fetch(`/api/public/incidents/${id}`).then(r=>r.json()).catch(()=>[]),
  ]);
  if (selectedServerId !== id) return; // user moved on
  renderDetail(server, uptime, heartbeat, incidents);
  cacheSet("detail-" + id, { uptime, heartbeat, incidents });
}

function renderDetailSkeleton(s){
  document.getElementById("mainArea").innerHTML = `
    <div class="detail-header">
      <div>
        <div class="detail-name">${s.name}</div>
        <div class="detail-host">${s.host}</div>
      </div>
    </div>
    <div class="uptime-row">
      ${["24h","7d","30d"].map(l=>`<div class="uptime-card"><div class="uptime-label">${l}</div><div class="dv-skeleton" style="height:32px;width:80px;margin:0 auto"></div></div>`).join("")}
    </div>
    <div class="dv-section"><div class="dv-section-head"><div class="dv-section-title">Heartbeat</div></div><div class="dv-section-body"><div class="dv-skeleton" style="height:28px"></div></div></div>
    <div class="dv-section"><div class="dv-section-head"><div class="dv-section-title">Response Time</div></div><div class="dv-section-body"><div class="dv-skeleton" style="height:120px"></div></div></div>
  `;
}

function renderDetail(s, uptime, heartbeat, incidents){
  uptime    = uptime    || {};
  heartbeat = heartbeat || [];
  incidents = incidents || [];
  const statusLabel = s.overall==="up"?"Online":s.overall==="down"?"Offline":s.overall==="degraded"?"Degraded":"Pending";
  const tags = (s.tags||[]).map(t=>`<span class="detail-tag">${t}</span>`).join("");

  const uptimeCards = [
    {label:"Last 24h", val:uptime.h24},
    {label:"Last 7 days", val:uptime.d7},
    {label:"Last 30 days", val:uptime.d30}
  ].map(u => `
    <div class="uptime-card">
      <div class="uptime-label">${u.label}</div>
      <div class="uptime-pct ${uptimeCls(u.val)}">${u.val !== null && u.val !== undefined ? u.val+"%" : "—"}</div>
      <div class="uptime-sub">${u.val >= 99 ? "Excellent" : u.val >= 95 ? "Good" : (u.val !== null && u.val !== undefined) ? "Needs attention" : "No data yet"}</div>
    </div>`).join("");

  const hbPad  = Math.max(0, 90 - heartbeat.length);
  const hbDots = [
    ...Array(hbPad).fill(null).map(() => `<div class="hb-dot pending" title="No data"></div>`),
    ...heartbeat.map(h => `<div class="hb-dot ${h.ok?"up":"down"}" title="${fmtTime(h.checked_at)} — ${h.ok?"Up":"Down"}${h.response_ms?" ("+h.response_ms+"ms)":""}"></div>`)
  ].join("");

  const checkChips = (s.checks||[]).map(c => {
    const lbl     = c.type==="ping"?"Ping":c.type==="tcp"?`TCP :${c.port}`:c.type==="udp"?`UDP :${c.port}`:"HTTP";
    const chipCls = c.ok ? "ok" : "fail";
    return `<div class="dv-chip ${chipCls}">
      <div class="dv-chip-dot"></div>
      <span class="dv-chip-label">${lbl}</span>
      <span class="dv-chip-detail">${c.detail||""}</span>
    </div>`;
  }).join("");

  const incidentRows = incidents.length === 0
    ? `<div class="no-incidents">No incidents recorded</div>`
    : incidents.map(i => `
      <div class="incident-row">
        <div class="incident-dot ${i.ended_at?"resolved":""}"></div>
        <div>
          <div class="incident-cause">${i.cause||"Service unavailable"}</div>
          <div class="incident-time">${fmtTime(i.started_at)}${i.ended_at?" → "+fmtTime(i.ended_at):""}</div>
        </div>
        <div class="incident-dur ${i.ended_at?"resolved":"open"}">${i.ended_at?fmtDur(i.duration_s):"ONGOING"}</div>
      </div>`).join("");

  const lastChecked = s.lastChecked ? `Last checked ${new Date(s.lastChecked).toLocaleTimeString()}` : "Not yet checked";

  // Edit button — always visible on the admin page's detail view (user is already authed).
  // Clicking opens the same form used by the Servers tab, pre-filled for this server.
  const editButton = `<button type="button" class="detail-edit-btn" onclick="editFromDetail('${s.id}')" title="Edit server">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      Edit server
    </button>`;

  document.getElementById("mainArea").innerHTML = `
    <div class="detail-header">
      <div>
        <div class="detail-name">${s.name}</div>
        <div class="detail-host">${s.host}${s.description ? " — "+s.description : ""}</div>
        <div class="detail-tags">${tags}</div>
      </div>
      <div class="detail-actions">
        ${editButton}
        <div class="status-big ${s.overall||'pending'}">
          <div class="status-big-dot"></div>
          <div>
            <div class="status-big-label">${statusLabel}</div>
            <div class="status-big-time">${lastChecked}</div>
          </div>
        </div>
      </div>
    </div>

    <div class="uptime-row">${uptimeCards}</div>

    <div class="dv-section">
      <div class="dv-section-head"><div class="dv-section-title">Current Checks</div></div>
      <div class="dv-section-body">
        <div class="checks-row">${checkChips || "<span style='color:var(--text-2);font-size:12px'>No checks configured</span>"}</div>
      </div>
    </div>

    <div class="dv-section">
      <div class="dv-section-head">
        <div class="dv-section-title">Heartbeat</div>
        <span style="font-size:11px;color:var(--text-2)">Last 90 checks</span>
      </div>
      <div class="dv-section-body">
        <div class="heartbeat">${hbDots}</div>
        <div class="hb-legend">
          <span>${heartbeat.length > 0 ? fmtTime(heartbeat[0].checked_at) : ""}</span>
          <span style="display:flex;align-items:center;gap:10px">
            <span style="display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:2px;background:var(--green);display:inline-block"></span> Up</span>
            <span style="display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:2px;background:var(--red);display:inline-block"></span> Down</span>
          </span>
          <span>Now</span>
        </div>
      </div>
    </div>

    <div class="dv-section">
      <div class="dv-section-head">
        <div class="dv-section-title">Response Time</div>
        <span style="font-size:11px;color:var(--text-2)">Last 24h (avg ms)</span>
      </div>
      <div class="dv-section-body" style="padding:16px 20px">
        ${heartbeat.filter(h=>h.response_ms).length > 0
          ? `<div class="chart-wrap"><canvas id="responseChart"></canvas></div>`
          : `<div class="chart-empty">No response time data yet — check back after a few cycles</div>`
        }
      </div>
    </div>

    <div class="dv-section">
      <div class="dv-section-head">
        <div class="dv-section-title">Incident History</div>
        <span style="font-size:11px;color:var(--text-2)">${incidents.length} incident${incidents.length===1?"":"s"}</span>
      </div>
      <div class="dv-section-body" style="padding:0 20px">
        <div class="incident-list">${incidentRows}</div>
      </div>
    </div>
  `;

  const chartData = heartbeat.filter(h => h.response_ms !== null && h.response_ms !== undefined);
  if (chartData.length > 0) drawChart(chartData);
}

function drawChart(data){
  const canvas = document.getElementById("responseChart");
  if (!canvas) return;
  const dpr  = window.devicePixelRatio || 1;
  const rect = canvas.parentElement.getBoundingClientRect();
  canvas.width  = rect.width  * dpr;
  canvas.height = 120 * dpr;
  canvas.style.width  = rect.width  + "px";
  canvas.style.height = "120px";
  const ctx = canvas.getContext("2d");
  ctx.scale(dpr, dpr);
  const W = rect.width, H = 120, PAD = {top:10, right:10, bottom:24, left:40};
  const cW = W - PAD.left - PAD.right;
  const cH = H - PAD.top  - PAD.bottom;
  const vals = data.map(d => d.response_ms);
  const maxV = Math.max(...vals, 10);
  const minV = 0;
  ctx.clearRect(0, 0, W, H);

  ctx.strokeStyle = "rgba(30,100,200,0.1)";
  ctx.lineWidth   = 1;
  [0, 0.25, 0.5, 0.75, 1].forEach(f => {
    const y = PAD.top + cH * (1 - f);
    ctx.beginPath(); ctx.moveTo(PAD.left, y); ctx.lineTo(W - PAD.right, y); ctx.stroke();
    ctx.fillStyle = "rgba(61,96,128,0.8)";
    ctx.font      = "10px JetBrains Mono, monospace";
    ctx.textAlign = "right";
    ctx.fillText(Math.round(maxV * f) + "ms", PAD.left - 4, y + 3);
  });

  const grad = ctx.createLinearGradient(0, PAD.top, 0, PAD.top + cH);
  grad.addColorStop(0, "rgba(42,127,255,0.3)");
  grad.addColorStop(1, "rgba(42,127,255,0.0)");
  ctx.fillStyle = grad;
  ctx.beginPath();
  data.forEach((d, i) => {
    const x = PAD.left + (i / (data.length - 1 || 1)) * cW;
    const y = PAD.top  + cH * (1 - (d.response_ms - minV) / (maxV - minV));
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.lineTo(PAD.left + cW, PAD.top + cH);
  ctx.lineTo(PAD.left, PAD.top + cH);
  ctx.closePath(); ctx.fill();

  ctx.strokeStyle = "rgba(42,127,255,0.9)";
  ctx.lineWidth   = 2;
  ctx.lineJoin    = "round";
  ctx.beginPath();
  data.forEach((d, i) => {
    const x = PAD.left + (i / (data.length - 1 || 1)) * cW;
    const y = PAD.top  + cH * (1 - (d.response_ms - minV) / (maxV - minV));
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.stroke();

  ctx.fillStyle = "rgba(42,127,255,1)";
  if (data.length <= 30) {
    data.forEach((d, i) => {
      const x = PAD.left + (i / (data.length - 1 || 1)) * cW;
      const y = PAD.top  + cH * (1 - (d.response_ms - minV) / (maxV - minV));
      ctx.beginPath(); ctx.arc(x, y, 3, 0, Math.PI * 2); ctx.fill();
    });
  }
}

