<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<%- include('partials/head', { title: 'Status Monitor — Admin' }) %>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root,[data-theme="dark"]{
  --bg:#060c18;--bg2:#0a1220;--surface:#0d1829;--surface2:#111f35;--surface3:#182440;
  --border:rgba(30,100,200,0.15);--border-hi:rgba(30,100,200,0.28);
  --text:#7a9cc0;--text-2:#3d6080;--text-hi:#c8dff0;--text-white:#e8f4ff;
  --shadow:rgba(0,0,20,0.5);--input-bg:#060c18;
  --glow-a:rgba(42,127,255,0.07);--glow-o:rgba(255,140,42,0.04);
}
[data-theme="light"]{
  --bg:#f0f5ff;--bg2:#e8f0fa;--surface:#fff;--surface2:#eef3fb;--surface3:#dde8f5;
  --border:rgba(42,100,200,0.12);--border-hi:rgba(42,100,200,0.22);
  --text:#4a6a90;--text-2:#8aaac8;--text-hi:#1a3a5c;--text-white:#0a1e3a;
  --shadow:rgba(0,20,80,0.08);--input-bg:#f8faff;
  --glow-a:rgba(42,127,255,0.05);--glow-o:rgba(255,140,42,0.03);
}
:root{
  --blue:#2a7fff;--blue-soft:rgba(42,127,255,0.12);--blue-glow:rgba(42,127,255,0.25);
  --orange:#ff8c2a;--orange-soft:rgba(255,140,42,0.12);--orange-glow:rgba(255,140,42,0.3);
  --green:#10e88a;--green-soft:rgba(16,232,138,0.10);
  --red:#ff3d5a;--red-soft:rgba(255,61,90,0.10);
  --warn:#ffb830;--warn-soft:rgba(255,184,48,0.10);
  --sans:'Inter',sans-serif;--mono:'JetBrains Mono',monospace;--r:10px;--r-sm:7px;
}

/* smooth theme transition */
*,*::before,*::after{transition:background-color .22s,border-color .22s,color .18s,box-shadow .22s}
.orb,.live-dot,.spark,svg *,.srv-dot{transition:none!important}

body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;font-size:14px;line-height:1.5;-webkit-font-smoothing:antialiased;overflow-x:hidden}

/* bg glow */
.bg-glow{position:fixed;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse 70% 50% at 15% 50%,var(--glow-a) 0%,transparent 70%),
             radial-gradient(ellipse 40% 40% at 85% 20%,var(--glow-o) 0%,transparent 60%)}

#app{position:relative;z-index:1;display:flex;flex-direction:column;min-height:100vh}

/* ── TOP BAR ── */
.topbar{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;height:54px;
  background:var(--bg2);border-bottom:1px solid var(--border);
  flex-shrink:0;position:sticky;top:0;z-index:100;
}
.brand{display:flex;align-items:center;gap:10px}
.brand-icon{width:28px;height:28px;border-radius:7px;background:var(--blue-soft);border:1px solid rgba(42,127,255,0.25);display:flex;align-items:center;justify-content:center;font-size:13px}
.brand-name{font-size:15px;font-weight:700;color:var(--text-white);letter-spacing:-.02em}
.brand-name span{color:var(--blue)}
.topbar-right{display:flex;align-items:center;gap:8px}
.topbar-dashboards{display:flex;align-items:center;gap:6px;flex:1;flex-wrap:wrap;margin:0 16px;min-width:0;overflow:hidden}
.dash-nav{display:inline-flex;align-items:center;gap:6px;padding:5px 11px;border-radius:var(--r-sm);border:1px solid var(--border-hi);background:var(--surface);color:var(--text-hi);cursor:pointer;font-family:var(--sans);font-size:11px;font-weight:500;text-decoration:none;white-space:nowrap;transition:background .15s,border-color .15s,color .15s}
.dash-nav:hover{background:var(--blue-soft);border-color:var(--blue);color:var(--blue)}
.dash-nav-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
/* Admin master-view pill — orange accent so it's visually distinct from the dashboard pills */
.dash-nav-admin{border-color:var(--border-hi);color:var(--text-hi);background:transparent}
.dash-nav-admin:hover{border-color:var(--orange);background:var(--orange-soft);color:var(--orange)}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;gap:6px;padding:6px 13px;font-family:var(--sans);font-size:12px;font-weight:500;border-radius:var(--r-sm);border:1px solid var(--border-hi);background:var(--surface);color:var(--text-hi);cursor:pointer;white-space:nowrap}
.btn:hover{background:var(--surface2);border-color:var(--blue);color:var(--text-white)}
.btn svg{width:13px;height:13px;flex-shrink:0;transition:none!important}
.btn.spinning svg{animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.btn-primary{background:var(--blue)!important;border-color:rgba(42,127,255,.5)!important;color:#fff!important}
.btn-primary:hover{background:#1a6fef!important}
.btn-danger{color:var(--red)!important;background:var(--red-soft)!important;border-color:rgba(255,61,90,.3)!important}
.btn-danger:hover{background:rgba(255,61,90,.2)!important}
.btn-icon{width:32px;height:32px;padding:0;justify-content:center;border-radius:var(--r-sm)}
.btn-logs{position:relative}
.log-badge{position:absolute;top:-5px;right:-5px;background:var(--red);color:#fff;font-size:9px;font-weight:700;min-width:15px;height:15px;border-radius:8px;display:flex;align-items:center;justify-content:center;padding:0 3px;border:2px solid var(--bg);opacity:0}
.log-badge.show{opacity:1}
.user-badge{font-family:var(--mono);font-size:11px;color:var(--text-2);background:var(--surface);border:1px solid var(--border);border-radius:var(--r-sm);padding:4px 10px}
[data-theme="light"] .icon-moon{display:none}
[data-theme="dark"]  .icon-sun{display:none}

/* ── MAIN LAYOUT ── */
.main-layout{display:flex;flex:1;overflow:hidden;height:calc(100vh - 54px)}

/* ── SIDEBAR ── */
.sidebar{width:260px;flex-shrink:0;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.sidebar-header{padding:14px 18px 10px;border-bottom:1px solid var(--border);flex-shrink:0}
.sidebar-section-title{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-2)}
.sidebar-body{flex:1;overflow-y:auto;padding:6px 0}
.sidebar-body::-webkit-scrollbar{width:3px}
.sidebar-body::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:2px}

/* Server rows in sidebar */
.srv-row{display:flex;align-items:center;gap:10px;padding:9px 18px;cursor:pointer;border-left:3px solid transparent;transition:background .12s,border-color .12s}
.srv-row:hover{background:var(--surface);border-left-color:var(--border-hi)}
.srv-row.active{background:var(--surface);border-left-color:var(--blue)}
.srv-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.srv-dot.up      {background:var(--green);box-shadow:0 0 5px rgba(16,232,138,.5)}
.srv-dot.down    {background:var(--red);animation:blink 1.2s ease-in-out infinite}
.srv-dot.degraded{background:var(--orange)}
.srv-dot.pending {background:var(--text-2)}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.srv-row-info{flex:1;min-width:0}
.srv-row-name{font-size:13px;font-weight:500;color:var(--text-hi);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.srv-row.active .srv-row-name{color:var(--text-white)}
.srv-row-host{font-family:var(--mono);font-size:10px;color:var(--text-2);margin-top:1px}
.srv-badge{font-size:10px;font-weight:600;padding:1px 7px;border-radius:8px;flex-shrink:0}
.srv-badge.up      {color:var(--green);background:var(--green-soft)}
.srv-badge.down    {color:var(--red);background:var(--red-soft)}
.srv-badge.degraded{color:var(--orange);background:var(--orange-soft)}
.srv-badge.pending {color:var(--text-2);background:var(--surface2)}

/* Stats row in sidebar */
.sidebar-stats{padding:12px 18px;border-bottom:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px;flex-shrink:0}
.ss-card{text-align:center}
.ss-val{font-size:18px;font-weight:700;letter-spacing:-.02em;color:var(--text-white)}
.ss-lbl{font-size:9px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-2);margin-top:1px}
.ss-card.up   .ss-val{color:var(--green)}
.ss-card.down .ss-val{color:var(--red)}
.ss-card.warn .ss-val{color:var(--orange)}

/* Live pill */
.live-pill{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:500;color:var(--green);background:var(--green-soft);border:1px solid rgba(16,232,138,.2);border-radius:20px;padding:2px 8px}
.live-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:lpulse 2s ease-in-out infinite}
@keyframes lpulse{0%,100%{opacity:1}50%{opacity:.4}}

/* ── MAIN CONTENT AREA ── */
.content{flex:1;overflow-y:auto;background:var(--bg);padding:24px 28px}
.content::-webkit-scrollbar{width:4px}
.content::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:2px}

/* ── SERVER CARDS ── */
.server-list{display:flex;flex-direction:column;gap:6px}
.server-card{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--text-2);border-radius:var(--r);overflow:hidden;animation:cardIn .3s ease both}
@keyframes cardIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.server-card:hover{border-color:var(--border-hi);box-shadow:0 4px 20px var(--shadow)}
.server-card.up      {border-left-color:var(--green)}
.server-card.down    {border-left-color:var(--red)}
.server-card.degraded{border-left-color:var(--orange)}
.card-body{display:grid;grid-template-columns:auto 1fr auto auto auto;align-items:center;gap:14px;padding:13px 18px;cursor:pointer;user-select:none}
.card-orb{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.server-card.up       .card-orb{background:var(--green-soft);box-shadow:0 0 0 1px rgba(16,232,138,.22),0 0 12px rgba(16,232,138,.2)}
.server-card.down     .card-orb{background:var(--red-soft);box-shadow:0 0 0 1px rgba(255,61,90,.22);animation:blink 1.6s ease-in-out infinite}
.server-card.degraded .card-orb{background:var(--orange-soft);box-shadow:0 0 0 1px rgba(255,140,42,.22)}
.server-card.pending  .card-orb{background:var(--surface2)}
.card-info{min-width:0}
.card-name{font-size:14px;font-weight:600;color:var(--text-white);letter-spacing:-.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.card-meta{display:flex;align-items:center;gap:8px;margin-top:3px;flex-wrap:wrap}
.card-ip{font-family:var(--mono);font-size:11px;color:var(--text-2)}
.card-desc{font-size:11px;color:var(--text-2)}
.tags{display:flex;gap:4px;flex-wrap:wrap}
.tag{font-size:9px;font-weight:600;letter-spacing:.05em;padding:1px 6px;border-radius:3px;background:var(--surface2);color:var(--text-2);border:1px solid var(--border);text-transform:uppercase}
.sparkline{display:flex;gap:2px;align-items:flex-end;height:24px;flex-shrink:0}
.spark{width:4px;border-radius:2px;background:var(--surface2);height:50%}
.spark.ok{background:rgba(16,232,138,.4);height:100%}
.spark.ok:last-child{background:var(--green)}
.spark.bad{background:rgba(255,61,90,.5);height:55%}
.card-badge{flex-shrink:0;font-size:10px;font-weight:600;letter-spacing:.05em;padding:3px 10px;border-radius:20px;white-space:nowrap}
.card-badge.up      {color:var(--green);background:var(--green-soft);border:1px solid rgba(16,232,138,.2)}
.card-badge.down    {color:var(--red);background:var(--red-soft);border:1px solid rgba(255,61,90,.2)}
.card-badge.degraded{color:var(--orange);background:var(--orange-soft);border:1px solid rgba(255,140,42,.2)}
.card-badge.pending {color:var(--text-2);background:var(--surface2);border:1px solid var(--border)}
.card-chevron{width:14px;height:14px;color:var(--text-2);flex-shrink:0;transition:transform .2s!important}
.server-card.expanded .card-chevron{transform:rotate(180deg)}

/* check panel */
.check-panel{display:none;border-top:1px solid var(--border);padding:12px 18px 14px;background:var(--bg2);gap:8px;flex-wrap:wrap}
.check-panel.open{display:flex}
.check-chip{display:inline-flex;align-items:center;gap:7px;padding:6px 12px;border-radius:var(--r-sm);border:1px solid var(--border);background:var(--surface);font-size:12px}
.check-chip.ok  {border-color:rgba(16,232,138,.18)}
.check-chip.fail{border-color:rgba(255,61,90,.22)}
.chip-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.check-chip.ok   .chip-dot{background:var(--green)}
.check-chip.fail .chip-dot{background:var(--red)}
.chip-label {font-weight:500;color:var(--text-hi)}
.chip-detail{font-family:var(--mono);font-size:11px;color:var(--text-2);padding-left:6px;border-left:1px solid var(--border)}
.check-ts{width:100%;font-size:10px;color:var(--text-2);margin-top:2px}

/* section headers */
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.section-title{font-size:11px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--text-2)}

/* footer */
.page-footer{padding:12px 28px;border-top:1px solid var(--border);font-size:11px;color:var(--text-2);display:flex;justify-content:space-between;flex-shrink:0;background:var(--bg2)}

/* ══ DRAWER BASE ══ */
.drawer-overlay{position:fixed;inset:0;background:rgba(0,5,20,.5);backdrop-filter:blur(4px);z-index:200;opacity:0;pointer-events:none;transition:opacity .25s!important}
.drawer-overlay.open{opacity:1;pointer-events:all}
.drawer{position:fixed;top:0;right:0;bottom:0;background:var(--bg2);border-left:1px solid var(--border-hi);z-index:201;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .28s cubic-bezier(.4,0,.2,1)!important;box-shadow:-8px 0 40px var(--shadow);padding-top:env(safe-area-inset-top, 0px)}
/* On mobile, lift the drawer's bottom edge 28px above the gesture bar so the Save button
   can't be intercepted by Android gesture nav or iOS home indicator. env() adds extra if the
   browser reports a larger safe area — hence max() — otherwise we always get at least 28px. */
@media(max-width:760px){
  .drawer{bottom:max(28px, env(safe-area-inset-bottom, 28px))}
}
.drawer.open{transform:translateX(0)}
.drawer-header{padding:16px 18px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.drawer-title{font-size:14px;font-weight:600;color:var(--text-white);display:flex;align-items:center;gap:8px}
.drawer-title svg{width:15px;height:15px;color:var(--blue);transition:none!important}
.drawer-close{width:28px;height:28px;border-radius:6px;border:1px solid var(--border);background:var(--surface);color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px}
.drawer-close:hover{background:var(--surface2);color:var(--text-white)}
.drawer-toolbar{padding:10px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-shrink:0;flex-wrap:wrap}
.drawer-spacer{flex:1}
.drawer-body{flex:1;min-height:0;overflow-y:auto;overflow-x:hidden}
.drawer-body::-webkit-scrollbar{width:3px}
.drawer-body::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:2px}
.drawer-footer{padding:10px 18px;border-top:1px solid var(--border);font-size:11px;color:var(--text-2);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}

/* LOG DRAWER */
#logDrawer{width:min(540px,100vw)}
.filter-tabs{display:flex;gap:3px}
.filter-tab{padding:4px 11px;font-size:11px;font-weight:500;border-radius:5px;border:1px solid transparent;background:none;color:var(--text-2);cursor:pointer;font-family:var(--sans)}
.filter-tab:hover{color:var(--text-hi);background:var(--surface)}
.filter-tab.active{color:var(--text-white);background:var(--surface2);border-color:var(--border-hi)}
.auto-scroll-toggle{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text-2);cursor:pointer;user-select:none}
.toggle-track{width:26px;height:14px;border-radius:7px;background:var(--surface2);border:1px solid var(--border);position:relative;transition:background .2s!important}
.toggle-track.on{background:var(--blue);border-color:transparent}
.toggle-thumb{position:absolute;top:2px;left:2px;width:8px;height:8px;border-radius:50%;background:var(--text-2);transition:left .2s!important}
.toggle-track.on .toggle-thumb{left:14px;background:#fff}
.clear-btn{padding:4px 9px;font-size:11px;border-radius:5px;border:1px solid var(--border);background:none;color:var(--text-2);cursor:pointer;font-family:var(--sans)}
.clear-btn:hover{color:var(--red);border-color:rgba(255,61,90,.3)}
.log-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:10px;color:var(--text-2);font-size:12px;padding:40px}
.log-empty svg{width:28px;height:28px;opacity:.3;transition:none!important}
.log-entry{display:grid;grid-template-columns:72px 12px 95px 1fr;align-items:baseline;gap:0 8px;padding:5px 18px;border-bottom:1px solid var(--border);font-family:var(--mono);font-size:11px;animation:logIn .2s ease both}
@keyframes logIn{from{opacity:0;transform:translateX(4px)}to{opacity:1;transform:translateX(0)}}
.log-entry:hover{background:var(--surface2)}
.log-ts{color:var(--text-2);font-size:10px}
.log-icon{font-size:10px}
.log-entry.ok .log-icon{color:var(--green)}.log-entry.fail .log-icon{color:var(--red)}.log-entry.sys .log-icon{color:var(--blue)}.log-entry.change .log-icon{color:var(--orange)}
.log-server{color:var(--text);font-size:10px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.log-msg{color:var(--text-2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.log-entry.fail .log-msg{color:rgba(255,61,90,.85)}.log-entry.change .log-msg{color:var(--orange);font-weight:500}.log-entry.sys .log-msg{color:rgba(42,127,255,.9)}
.log-entry.change{background:rgba(255,140,42,.05);border-left:2px solid rgba(255,140,42,.4);padding-left:16px}
.log-entry.sys{background:rgba(42,127,255,.05)}

/* ADMIN DRAWER */
#adminDrawer{width:min(660px,100vw)}
/* flex:1 + min-height:0 is the classic flex scroll-container pattern.
   Using height:100% here overflowed the drawer by the drawer-header's height,
   pushing the sticky Save button below the visible viewport. */
.admin-section{display:flex;flex-direction:column;flex:1;min-height:0}
.admin-tabs{display:flex;gap:3px}
.admin-tab{padding:4px 13px;font-size:11px;font-weight:500;border-radius:5px;border:1px solid transparent;background:none;color:var(--text-2);cursor:pointer;font-family:var(--sans)}
.admin-tab:hover{color:var(--text-hi);background:var(--surface)}
.admin-tab.active{color:var(--text-white);background:var(--surface2);border-color:var(--border-hi)}
.admin-server-item{display:flex;align-items:center;gap:10px;padding:11px 18px;border-bottom:1px solid var(--border);cursor:pointer}
.admin-server-item:hover{background:var(--surface)}
.admin-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;transition:none!important}
.admin-dot.up{background:var(--green)}.admin-dot.down{background:var(--red)}.admin-dot.degraded{background:var(--orange)}.admin-dot.pending{background:var(--text-2)}
.admin-info{flex:1;min-width:0}
.admin-name{font-size:12px;font-weight:600;color:var(--text-white)}
.admin-host{font-family:var(--mono);font-size:10px;color:var(--text-2);margin-top:1px}
.admin-checks-label{font-size:10px;color:var(--text-2);margin-top:2px;display:flex;align-items:center;flex-wrap:wrap;gap:4px}
.chip-cert{display:inline-flex;align-items:center;gap:4px;font-size:9px;font-weight:600;padding:1px 6px;border-radius:8px;letter-spacing:.02em;white-space:nowrap}
.chip-cert.cert-ok     {color:var(--green);background:var(--green-soft);border:1px solid rgba(16,232,138,.25)}
.chip-cert.cert-warn   {color:var(--orange);background:var(--orange-soft);border:1px solid rgba(255,140,42,.3)}
.chip-cert.cert-expired{color:var(--red);background:var(--red-soft);border:1px solid rgba(255,61,90,.3)}
.admin-row-actions{display:flex;gap:5px;flex-shrink:0}
.empty-state{padding:32px;text-align:center;color:var(--text-2);font-size:12px;line-height:1.7}
.user-item{display:flex;align-items:center;gap:10px;padding:11px 18px;border-bottom:1px solid var(--border);cursor:pointer}
.user-item:hover{background:var(--surface)}
.user-avatar{width:30px;height:30px;border-radius:50%;background:var(--blue-soft);border:1px solid rgba(42,127,255,.22);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--blue);flex-shrink:0}
.user-info{flex:1;min-width:0}
.user-name{font-size:12px;font-weight:600;color:var(--text-white)}
.user-meta{font-size:10px;color:var(--text-2);margin-top:1px}
.user-dash-pills{display:flex;flex-wrap:wrap;gap:4px;margin-top:5px}
.user-dash-pill{display:inline-flex;align-items:center;padding:2px 8px;border-radius:10px;font-size:9px;font-weight:600;letter-spacing:.04em;background:transparent;border:1px solid var(--blue);color:var(--blue);text-transform:uppercase;white-space:nowrap}
.user-dash-pill.user-dash-all{background:var(--blue-soft);border-color:rgba(42,127,255,.35);color:var(--blue)}
.user-dash-pill.user-dash-none{background:var(--surface2);border-color:var(--border);color:var(--text-2);text-transform:none}
.role-badge{font-size:9px;font-weight:700;letter-spacing:.05em;padding:2px 7px;border-radius:8px;text-transform:uppercase}
.role-badge.admin {color:var(--blue);background:var(--blue-soft);border:1px solid rgba(42,127,255,.25)}
.role-badge.viewer{color:var(--text-2);background:var(--surface2);border:1px solid var(--border)}

/* FORM */
.form-wrap{padding:18px}
.form-heading{font-size:14px;font-weight:700;color:var(--text-white);margin-bottom:16px}
.form-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:12px}
.fg{display:flex;flex-direction:column;gap:4px}
.fg.full{grid-column:1/-1}
.flabel{font-size:10px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--text-2)}
.finput,.fselect{width:100%;padding:8px 11px;background:var(--input-bg);border:1px solid var(--border-hi);border-radius:var(--r-sm);color:var(--text-white);font-family:var(--sans);font-size:12px;outline:none}
.finput:focus,.fselect:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(42,127,255,.12)}
.finput::placeholder{color:var(--text-2)}
.fselect option{background:var(--surface2)}
.checks-wrap{grid-column:1/-1}
.checks-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.check-rows{display:flex;flex-direction:column;gap:7px}
.crow{display:flex;align-items:center;gap:7px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r-sm);padding:8px 10px}
.crow .fselect{width:115px;flex-shrink:0;padding:5px 7px;font-size:11px}
.crow .finput{padding:5px 9px;font-size:11px}
.crow-detail{flex:1;display:flex;gap:7px}
.crow-hint{font-size:10px;color:var(--text-2);align-self:center}
.rm-check{width:24px;height:24px;border-radius:4px;border:1px solid var(--border);background:none;color:var(--text-2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}
.rm-check:hover{border-color:rgba(255,61,90,.4);color:var(--red);background:var(--red-soft)}
.no-checks{font-size:11px;color:var(--text-2);padding:10px;text-align:center;border:1px dashed var(--border-hi);border-radius:var(--r-sm)}
.form-footer{display:flex;align-items:center;justify-content:flex-end;gap:8px;padding:16px 18px;border-top:1px solid var(--border);background:var(--bg2);position:sticky;bottom:0;margin:16px -18px 0;z-index:3}
@media(max-width:760px){.form-footer{padding:18px 16px 22px 16px}}
.form-err{flex:1;font-size:11px;color:var(--red)}

/* CONFIRM */
.confirm-overlay{position:fixed;inset:0;background:rgba(0,5,20,.6);backdrop-filter:blur(6px);z-index:400;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s!important}
.confirm-overlay.open{opacity:1;pointer-events:all}
.confirm-box{background:var(--surface);border:1px solid var(--border-hi);border-radius:var(--r);padding:22px;max-width:340px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.6)}
.confirm-title{font-size:15px;font-weight:700;color:var(--text-white);margin-bottom:8px}
.confirm-msg{font-size:12px;color:var(--text);margin-bottom:18px;line-height:1.6}
.confirm-btns{display:flex;justify-content:flex-end;gap:8px}

/* CHANGE PWD MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,5,20,.55);backdrop-filter:blur(6px);z-index:400;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s!important}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal-box{background:var(--surface);border:1px solid var(--border-hi);border-radius:var(--r);padding:24px;max-width:360px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.6)}
.modal-title{font-size:14px;font-weight:700;color:var(--text-white);margin-bottom:16px}
.modal-group{display:flex;flex-direction:column;gap:4px;margin-bottom:12px}
.modal-label{font-size:10px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--text-2)}
.modal-input{width:100%;padding:8px 11px;background:var(--input-bg);border:1px solid var(--border-hi);border-radius:var(--r-sm);color:var(--text-white);font-family:var(--sans);font-size:12px;outline:none}
.modal-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(42,127,255,.12)}
.modal-footer{display:flex;align-items:center;justify-content:flex-end;gap:8px;margin-top:16px;padding-top:14px;border-top:1px solid var(--border)}
.modal-err{flex:1;font-size:11px;color:var(--red)}

/* USER FORM */
#aUserFormView{display:none;flex-direction:column;height:100%}

/* TOAST */
.toast-stack{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column-reverse;gap:6px;z-index:500;align-items:center;pointer-events:none}
.toast{padding:9px 16px;border-radius:var(--r-sm);font-size:12px;font-weight:500;white-space:nowrap;animation:toastIn .25s ease both;display:flex;align-items:center;gap:7px;box-shadow:0 4px 20px rgba(0,0,0,.5)}
@keyframes toastIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.toast.success{background:#032818;color:#4ade80;border:1px solid rgba(16,232,138,.3)}
.toast.error  {background:#1a0508;color:#fca5a5;border:1px solid rgba(255,61,90,.3)}
.toast.info   {background:var(--surface2);color:var(--text-hi);border:1px solid var(--border-hi)}

@media(max-width:760px){
  .topbar{padding:8px 10px;height:auto;min-height:48px;flex-wrap:wrap;gap:6px;row-gap:6px;position:sticky}
  .brand{flex-shrink:0;gap:8px}
  .brand-name{font-size:13px}
  .brand-icon{width:26px;height:26px}
  #clock{display:none}
  .topbar-dashboards{width:100%;order:3;margin:0;flex-basis:100%;overflow-x:auto;flex-wrap:nowrap;padding-bottom:2px}
  .dash-nav{padding:4px 9px;font-size:10px}
  .topbar-right{gap:6px;flex-wrap:wrap;justify-content:flex-end;flex:1;min-width:0}
  .btn{padding:5px 9px;font-size:11px;gap:5px}
  .btn svg{width:12px;height:12px}
  .btn-icon{width:30px;height:30px;padding:0}
  .user-badge{font-size:10px;padding:3px 8px}
  .main-layout{flex-direction:column;height:auto;overflow:visible}
  .sidebar{width:100%;height:auto;border-right:none;border-bottom:1px solid var(--border)}
  .sidebar-body{max-height:240px}
  .sidebar-stats{grid-template-columns:repeat(4,1fr);padding:10px 14px;gap:6px}
  .ss-val{font-size:15px}
  .ss-lbl{font-size:8px}
  .sparkline,.card-badge{display:none}
  .card-body{grid-template-columns:auto 1fr auto;padding:11px 14px}
  #logDrawer,#adminDrawer{width:100vw}
  .form-grid{grid-template-columns:minmax(0,1fr)}
  .content{padding:14px 12px}
  .page-footer{padding:10px 12px;font-size:10px;flex-wrap:wrap;gap:6px}
  /* Detail view shrinks */
  #mainArea .detail-header{flex-direction:column;gap:10px;margin-bottom:18px}
  #mainArea .detail-name{font-size:18px}
  #mainArea .uptime-row{grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:18px}
  #mainArea .uptime-card{padding:12px 6px}
  #mainArea .uptime-pct{font-size:20px}
  #mainArea .uptime-label{font-size:9px}
  #mainArea .uptime-sub{font-size:9px}
  #mainArea .dv-section{margin-bottom:14px}
  #mainArea .dv-section-head{padding:11px 14px}
  #mainArea .dv-section-body{padding:14px}
  #mainArea .heartbeat{gap:2px}
  #mainArea .hb-dot{width:7px;height:24px}
  #mainArea .checks-row{gap:6px}
  #mainArea .dv-chip{padding:6px 10px;font-size:11px}
  #mainArea .dv-chip-detail{font-size:10px}
  /* Health check rows: stack properly on narrow screens */
  .form-wrap{overflow-x:hidden;max-width:100%}
  .crow{flex-wrap:wrap;gap:6px}
  .crow .fselect{order:1;flex:1 1 auto;width:auto;min-width:0}
  .rm-check{order:2;flex-shrink:0}
  .crow-detail{order:3;flex:1 1 100%;display:flex;flex-wrap:wrap;gap:6px;min-width:0}
  .crow-detail .finput{flex:1 1 90px;min-width:0}
  .crow-detail .fselect{flex:0 0 auto;min-width:0}
}

/* ── DETAIL VIEW (scoped to #mainArea to avoid conflicts) ────────────────── */
#mainArea{display:flex;flex-direction:column;gap:0}
#mainArea .empty-main{display:flex;align-items:center;justify-content:center;height:60vh;color:var(--text-2);font-size:14px}

#mainArea .detail-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px;gap:16px;flex-wrap:wrap}
#mainArea .detail-name{font-size:22px;font-weight:700;color:var(--text-white);letter-spacing:-.02em}
#mainArea .detail-host{font-family:var(--mono);font-size:12px;color:var(--text-2);margin-top:4px}
#mainArea .detail-tags{display:flex;gap:5px;margin-top:6px;flex-wrap:wrap}
#mainArea .detail-tag{font-size:10px;font-weight:600;letter-spacing:.05em;padding:2px 8px;border-radius:4px;background:var(--surface2);color:var(--text-2);border:1px solid var(--border);text-transform:uppercase}

#mainArea .status-big{display:flex;align-items:center;gap:10px;padding:10px 18px;border-radius:10px;border:1px solid;flex-shrink:0}
#mainArea .detail-actions{display:flex;align-items:center;gap:10px;flex-shrink:0;flex-wrap:wrap}
#mainArea .detail-edit-btn{display:inline-flex;align-items:center;gap:6px;padding:10px 16px;background:var(--blue);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;font-family:var(--sans);transition:background .15s,transform .1s;text-decoration:none}
#mainArea .detail-edit-btn:hover{background:#1a6fef}
#mainArea .detail-edit-btn:active{transform:scale(.98)}
#mainArea .detail-edit-btn svg{width:14px;height:14px}
#mainArea .status-big.up      {color:var(--green);border-color:rgba(16,232,138,.2);background:var(--green-soft)}
#mainArea .status-big.down    {color:var(--red);border-color:rgba(255,61,90,.2);background:var(--red-soft)}
#mainArea .status-big.degraded{color:var(--orange);border-color:rgba(255,140,42,.2);background:var(--orange-soft)}
#mainArea .status-big.pending {color:var(--text-2);border-color:var(--border);background:var(--surface)}
#mainArea .status-big-dot{width:10px;height:10px;border-radius:50%;background:currentColor}
#mainArea .status-big.up .status-big-dot{animation:pulseDV 2s ease-in-out infinite}
@keyframes pulseDV{0%,100%{box-shadow:0 0 0 0 rgba(16,232,138,.4)}50%{box-shadow:0 0 0 5px transparent}}
#mainArea .status-big-label{font-size:13px;font-weight:700;letter-spacing:.05em}
#mainArea .status-big-time{font-size:11px;opacity:.7;margin-top:2px}

#mainArea .uptime-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:24px}
#mainArea .uptime-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 20px;text-align:center}
#mainArea .uptime-label{font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-2);margin-bottom:8px}
#mainArea .uptime-pct{font-size:28px;font-weight:700;letter-spacing:-.03em;line-height:1}
#mainArea .uptime-pct.great{color:var(--green)}
#mainArea .uptime-pct.good {color:var(--blue)}
#mainArea .uptime-pct.warn {color:var(--orange)}
#mainArea .uptime-pct.bad  {color:var(--red)}
#mainArea .uptime-sub{font-size:11px;color:var(--text-2);margin-top:4px}

#mainArea .dv-section{background:var(--surface);border:1px solid var(--border);border-radius:10px;margin-bottom:20px;overflow:hidden}
#mainArea .dv-section-head{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid var(--border)}
#mainArea .dv-section-title{font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-2)}
#mainArea .dv-section-body{padding:20px}

#mainArea .heartbeat{display:flex;gap:3px;align-items:flex-end;flex-wrap:wrap}
#mainArea .hb-dot{width:10px;height:28px;border-radius:3px;flex-shrink:0;transition:opacity .2s;cursor:pointer}
#mainArea .hb-dot.up     {background:var(--green);opacity:.7}
#mainArea .hb-dot.up:last-child{opacity:1}
#mainArea .hb-dot.down   {background:var(--red);opacity:.9}
#mainArea .hb-dot.pending{background:var(--surface2)}
#mainArea .hb-dot:hover  {opacity:1!important}
#mainArea .hb-legend{display:flex;align-items:center;justify-content:space-between;font-size:11px;color:var(--text-2);margin-top:8px}

#mainArea .chart-wrap{position:relative;height:120px;width:100%}
#mainArea canvas#responseChart{width:100%!important}
#mainArea .chart-empty{display:flex;align-items:center;justify-content:center;height:120px;font-size:13px;color:var(--text-2)}

#mainArea .checks-row{display:flex;gap:10px;flex-wrap:wrap}
#mainArea .dv-chip{display:inline-flex;align-items:center;gap:8px;padding:8px 14px;border-radius:8px;font-size:12px;border:1px solid;background:var(--surface)}
#mainArea .dv-chip.ok  {border-color:rgba(16,232,138,.2);background:var(--green-soft)}
#mainArea .dv-chip.fail{border-color:rgba(255,61,90,.2);background:var(--red-soft)}
#mainArea .dv-chip-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
#mainArea .dv-chip.ok   .dv-chip-dot{background:var(--green)}
#mainArea .dv-chip.fail .dv-chip-dot{background:var(--red)}
#mainArea .dv-chip-label {font-weight:500;color:var(--text-hi)}
#mainArea .dv-chip-detail{font-family:var(--mono);font-size:11px;color:var(--text-2);padding-left:6px;border-left:1px solid var(--border)}

#mainArea .incident-list{display:flex;flex-direction:column;gap:0}
#mainArea .incident-row{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:16px;padding:12px 0;border-bottom:1px solid var(--border)}
#mainArea .incident-row:last-child{border-bottom:none}
#mainArea .incident-dot{width:8px;height:8px;border-radius:50%;background:var(--red);flex-shrink:0}
#mainArea .incident-dot.resolved{background:var(--green)}
#mainArea .incident-cause{font-size:13px;color:var(--text-hi);font-weight:500}
#mainArea .incident-time{font-size:11px;color:var(--text-2);margin-top:2px;font-family:var(--mono)}
#mainArea .incident-dur{font-size:12px;font-weight:600;text-align:right}
#mainArea .incident-dur.resolved{color:var(--text-2)}
#mainArea .incident-dur.open{color:var(--red)}
#mainArea .no-incidents{text-align:center;padding:20px;color:var(--text-2);font-size:13px}

#mainArea .dv-skeleton{background:linear-gradient(90deg,var(--surface) 25%,var(--surface2) 50%,var(--surface) 75%);background-size:200% 100%;animation:dvShimmer 1.5s infinite;border-radius:6px}
@keyframes dvShimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
</style>
</head>
<body>
<div class="bg-glow"></div>
<div class="drawer-overlay" id="sharedOverlay" onclick="closeAll()"></div>

<!-- Confirm dialog -->
<div class="confirm-overlay" id="confirmDlg">
  <div class="confirm-box">
    <div class="confirm-title">Are you sure?</div>
    <div class="confirm-msg" id="confirmMsg"></div>
    <div class="confirm-btns"><button class="btn" onclick="closeConfirm()">Cancel</button><button class="btn btn-danger" onclick="void(0)">Remove</button></div>
  </div>
</div>

<!-- Change Password Modal -->
<div class="modal-overlay" id="changePwdModal">
  <div class="modal-box">
    <div class="modal-title">Change Password</div>
    <div class="modal-group"><label class="modal-label">Current Password</label><input class="modal-input" id="pwdCurrent" type="password" placeholder="Current password"></div>
    <div class="modal-group"><label class="modal-label">New Password</label><input class="modal-input" id="pwdNew" type="password" placeholder="Min 8 characters"></div>
    <div class="modal-group"><label class="modal-label">Confirm New Password</label><input class="modal-input" id="pwdConfirm" type="password" placeholder="Repeat new password"></div>
    <div class="modal-footer"><span class="modal-err" id="pwdErr"></span><button class="btn" onclick="closeChangePassword()">Cancel</button><button class="btn btn-primary" onclick="submitChangePassword()">Update</button></div>
  </div>
</div>

<div class="toast-stack" id="toasts"></div>

<!-- LOG DRAWER -->
<div class="drawer" id="logDrawer">
  <div class="drawer-header">
    <div class="drawer-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>Check Logs</div>
    <button class="drawer-close" onclick="closeLogs()">✕</button>
  </div>
  <div class="drawer-toolbar">
    <div class="filter-tabs"><button class="filter-tab active" onclick="setLF('all',this)">All</button><button class="filter-tab" onclick="setLF('error',this)">Errors</button><button class="filter-tab" onclick="setLF('changes',this)">Changes</button></div>
    <div class="drawer-spacer"></div>
    <div class="auto-scroll-toggle" onclick="toggleAS()"><div class="toggle-track on" id="asTrk"><div class="toggle-thumb"></div></div><span>Auto-scroll</span></div>
    <button class="clear-btn" onclick="clearLogs()">Clear</button>
  </div>
  <div class="drawer-body" style="padding:6px 0" id="logBody"><div class="log-empty"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>Connecting to log stream...</div></div>
  <div class="drawer-footer"><span id="logCount">0 entries</span><div class="live-pill"><div class="live-dot"></div> Live</div></div>
</div>

<!-- ADMIN DRAWER -->
<div class="drawer" id="adminDrawer">
  <div class="drawer-header">
    <div class="drawer-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>Manage</div>
    <button class="drawer-close" onclick="closeAdmin()">✕</button>
  </div>
  <div id="aListView" class="admin-section">
    <div class="drawer-toolbar">
      <div class="admin-tabs"><button class="admin-tab active" id="tabServers" onclick="switchTab('servers')">Servers</button><button class="admin-tab" id="tabGroups" onclick="switchTab('groups')">Groups</button><button class="admin-tab" id="tabOmada" onclick="switchTab('omada')">Omada</button><button class="admin-tab" id="tabUsers" onclick="switchTab('users')">Users</button><button class="admin-tab" id="tabWebhooks" onclick="switchTab('webhooks')">Webhooks</button></div>
      <span style="font-size:11px;color:var(--text-2)" id="aCount"></span>
      <div class="drawer-spacer"></div>
      <button class="btn btn-primary" id="addBtn" onclick="showServerForm(null)" style="font-size:11px;padding:5px 11px"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg><span id="addBtnLabel">Add Server</span></button>
    </div>
    <div class="drawer-body" id="adminPanelBody"></div>
    <div class="drawer-footer"><span>Saves to MariaDB instantly</span><span style="color:var(--blue);font-size:10px">Click to edit</span></div>
  </div>
  <div id="aFormView" class="admin-section" style="display:none">
    <div class="drawer-body">
      <div class="form-wrap">
        <div class="form-heading" id="fHeading">Add Server</div>
        <input type="hidden" id="fId">
        <div class="form-grid">
          <div class="fg"><label class="flabel">Server Name *</label><input class="finput" id="fName" placeholder="e.g. Web Server"></div>
          <div class="fg"><label class="flabel">Host / IP *</label><input class="finput" id="fHost" placeholder="e.g. 10.0.0.2"></div>
          <div class="fg full"><label class="flabel">Description</label><input class="finput" id="fDesc" placeholder="Short description"></div>
          <div class="fg full"><label class="flabel">Tags <span style="font-weight:400;text-transform:none;letter-spacing:0">(comma-separated)</span></label><input class="finput" id="fTags" placeholder="production, web, db"></div>
          <div class="fg"><label class="flabel">Poll Interval <span style="font-weight:400;text-transform:none;letter-spacing:0;color:var(--text-2)">(seconds, min 10)</span></label>
            <select class="fselect" id="fInterval">
              <option value="20">20s (fast)</option>
              <option value="30" selected>30s (default)</option>
              <option value="60">1m</option>
              <option value="300">5m</option>
              <option value="600">10m</option>
            </select>
          </div>
          <div class="fg"></div>
          <div class="fg full"><label class="flabel">Dashboards <span style="font-weight:400;text-transform:none;letter-spacing:0;color:var(--text-2)" id="fGroupsHint">(pick one or more — this server appears in each)</span></label>
