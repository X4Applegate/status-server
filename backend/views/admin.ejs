function renderCrows(){
  const c = document.getElementById("crowContainer");
  if (!currentChecks.length){ c.innerHTML = "<div class=\"no-checks\">No checks yet</div>"; return; }
  c.innerHTML = currentChecks.map((ck, i) => {
    const sel = (t) => ck.type===t ? "selected" : "";
    let detail = "";
    if (ck.type === "ping") {
      detail = "<span class=\"crow-hint\">No extra config needed</span>";
    } else if (ck.type === "tcp") {
      detail = "<input class=\"finput\" placeholder=\"Port e.g. 3306\" value=\"" + (ck.port||"") + "\" oninput=\"upCk(" + i + ",'port',parseInt(this.value)||0)\" style=\"max-width:160px\">";
    } else if (ck.type === "udp") {
      detail = "<input class=\"finput\" placeholder=\"Port e.g. 51820\" value=\"" + (ck.port||"") + "\" oninput=\"upCk(" + i + ",'port',parseInt(this.value)||0)\" style=\"max-width:160px\"><span class=\"crow-hint\">WireGuard: 51820</span>";
    } else if (ck.type === "http") {
      // Existing checks default to showing cert info (show_cert undefined or true).
      // Only when explicitly false do we hide the cert chip.
      const showCert = ck.show_cert !== false;
      detail =
        `<input class="finput" placeholder="URL" value="${ck.url||""}" oninput="upCk(${i},'url',this.value)">` +
        `<input class="finput" placeholder="Status" value="${ck.expectedStatus||200}" oninput="upCk(${i},'expectedStatus',parseInt(this.value))" style="max-width:90px">` +
        `<label class="crow-hint" style="display:flex;align-items:center;gap:5px;cursor:pointer;white-space:nowrap" title="Show SSL certificate expiry on the detail view (HTTPS only)">` +
          `<input type="checkbox" ${showCert ? "checked" : ""} onchange="upCk(${i},'show_cert',this.checked)" style="margin:0">` +
          `SSL info` +
        `</label>`;
    } else if (ck.type === "dns") {
      // DNS check — hostname, record type dropdown, optional expected value
      const rtype = (ck.record_type || "A").toUpperCase();
      const rtOpt = (t) => `<option value="${t}" ${rtype === t ? "selected" : ""}>${t}</option>`;
      detail =
        `<input class="finput" placeholder="Hostname e.g. example.com" value="${ck.hostname || ""}" oninput="upCk(${i},'hostname',this.value)" style="max-width:200px">` +
        `<select class="fselect" onchange="upCk(${i},'record_type',this.value)" style="max-width:90px">` +
          ["A","AAAA","CNAME","MX","TXT","NS"].map(rtOpt).join("") +
        `</select>` +
        `<input class="finput" placeholder="Expected value (optional)" value="${ck.expected || ""}" oninput="upCk(${i},'expected',this.value)">`;
    } else if (ck.type === "omada_gateway" || ck.type === "omada_lte") {
      // Controller dropdown + site dropdown.
      // Site dropdown gets populated lazily by populateOmadaSitePicker(i) once a controller is chosen.
      const ctrlOpts = adminOmada.map(c2 => `<option value="${c2.id}" ${ck.controller_id == c2.id ? "selected" : ""}>${c2.name}</option>`).join("");
      const ctrlSelect = adminOmada.length
        ? `<select class="fselect" onchange="upCk(${i},'controller_id',parseInt(this.value)); upCk(${i},'site_id',''); populateOmadaSitePicker(${i})"><option value="">— Controller —</option>${ctrlOpts}</select>`
        : `<span class="crow-hint" style="color:var(--red)">No Omada controllers configured. Add one in the Omada tab.</span>`;
      // Site picker — onchange is wired up in populateOmadaSitePicker (handles MSP customer encoding)
      const siteSelect = ck.controller_id
        ? `<select class="fselect" id="siteSel${i}"><option value="">${ck.site_id ? "Loading…" : "— Pick site —"}</option></select>`
        : "";
      // LTE-only: optional probe IP for controllers whose API doesn't expose cellular status
      const probeIpField = ck.type === "omada_lte"
        ? `<input class="finput" placeholder="LTE probe IP (optional)" title="If your controller doesn't expose cellular status via API, enter the LTE WAN IP to ping directly" value="${ck.probe_ip||""}" oninput="upCk(${i},'probe_ip',this.value)" style="max-width:160px">`
        : "";
      detail = ctrlSelect + siteSelect + probeIpField;
    }
    return "<div class=\"crow\">"
      + "<select class=\"fselect\" onchange=\"changeCT(" + i + ",this.value)\">"
      + "<option value=\"ping\" " + sel("ping") + ">Ping (ICMP)</option>"
      + "<option value=\"tcp\" "  + sel("tcp")  + ">TCP Port</option>"
      + "<option value=\"udp\" "  + sel("udp")  + ">UDP Port</option>"
      + "<option value=\"http\" " + sel("http") + ">HTTP</option>"
      + "<option value=\"dns\" "  + sel("dns")  + ">DNS Record</option>"
      + "<option value=\"omada_gateway\" " + sel("omada_gateway") + ">Omada Gateway</option>"
      + "<option value=\"omada_lte\" "     + sel("omada_lte")     + ">Omada LTE / Cellular</option>"
      + "</select>"
      + "<div class=\"crow-detail\">" + detail + "</div>"
      + "<button class=\"rm-check\" onclick=\"rmCk(" + i + ")\">x</button>"
      + "</div>";
  }).join("");
  // After render, populate any omada site pickers that already have a controller selected
  currentChecks.forEach((ck, i) => {
    if ((ck.type === "omada_gateway" || ck.type === "omada_lte") && ck.controller_id) populateOmadaSitePicker(i);
  });
}

async function populateOmadaSitePicker(i){
  const ck = currentChecks[i];
  if (!ck || !ck.controller_id) return;
  const sel = document.getElementById("siteSel" + i);
  if (!sel) return;
  // Use cached site list if we have it
  let sites = omadaSitesCache[ck.controller_id];
  if (!sites) {
    try {
      const r = await fetch(`/api/admin/omada-controllers/${ck.controller_id}/sites`);
      if (r.ok) { sites = await r.json(); omadaSitesCache[ck.controller_id] = sites; }
    } catch(e) {}
  }
  if (!sites || !sites.length) {
    sel.innerHTML = `<option value="">— No sites returned —</option>`;
    return;
  }
  // Encode "customerId|siteId" for MSP, plain siteId otherwise
  // For MSP sites, group by customer using <optgroup> so the picker shows
  // Customer A
  //   ├─ Site 1
  //   └─ Site 2
  const hasCustomers = sites.some(s => s.customerId);
  if (hasCustomers) {
    // Group by customer
    const byCust = {};
    sites.forEach(s => {
      const key = s.customerId || "_uncategorized";
      if (!byCust[key]) byCust[key] = { name: s.customerName || key, items: [] };
      byCust[key].items.push(s);
    });
    let html = `<option value="">— Pick site —</option>`;
    for (const [cid, group] of Object.entries(byCust)) {
      html += `<optgroup label="${group.name}">`;
      for (const s of group.items) {
        const sid     = s.siteId || s.id;
        const value   = `${s.customerId}|${sid}`;
        const matches = ck.site_id == sid && ck.customer_id == s.customerId;
        html += `<option value="${value}" ${matches ? "selected" : ""}>${s.name || sid}</option>`;
      }
      html += `</optgroup>`;
    }
    sel.innerHTML = html;
  } else {
    sel.innerHTML = `<option value="">— Pick site —</option>` +
      sites.map(s => {
        const sid     = s.siteId || s.id;
        const matches = ck.site_id == sid && !ck.customer_id;
        return `<option value="${sid}" ${matches ? "selected" : ""}>${s.name || sid}</option>`;
      }).join("");
  }
  // Wire onchange — parse the encoded value into customer_id (optional) + site_id,
  // then look up the chosen site from the cached site list to also store the
  // friendly site_name and customer_name (required for MSP filtering).
  sel.onchange = function(){
    const parts = this.value.split("|");
    let cid, sid;
    if (parts.length === 2) { cid = parts[0]; sid = parts[1]; }
    else                    { cid = null;     sid = parts[0]; }
    upCk(i, "customer_id", cid);
    upCk(i, "site_id",     sid);
    // Look up the picked site to grab its name + customer name
    const sitesList = omadaSitesCache[ck.controller_id] || [];
    const picked = sitesList.find(s => (s.siteId || s.id) === sid);
    upCk(i, "site_name",     picked?.name || null);
    upCk(i, "customer_name", picked?.customerName || null);
  };
}

function addCrow()    { currentChecks.push({type:"ping"}); renderCrows(); }
function rmCk(i)      { currentChecks.splice(i,1); renderCrows(); }
function changeCT(i,t){
  // When switching to omada_lte, seed controller+site from an existing omada_gateway check
  // on the same server so the user doesn't have to re-pick from scratch.
  if (t === "omada_lte" || t === "omada_gateway") {
    const donor = currentChecks.find((c,j) => j !== i && (c.type === "omada_gateway" || c.type === "omada_lte") && c.controller_id);
    if (donor) {
      currentChecks[i] = { type:t, controller_id:donor.controller_id, site_id:donor.site_id, site_name:donor.site_name, customer_id:donor.customer_id, customer_name:donor.customer_name };
      renderCrows();
      return;
    }
  }
  currentChecks[i] = {type:t}; renderCrows();
}
function upCk(i,k,v)  { currentChecks[i][k] = v; }

async function submitForm(){
  const name = document.getElementById("fName").value.trim();
  const host = document.getElementById("fHost").value.trim();
  if (!name || !host){ document.getElementById("fErr").textContent = "Name and host required."; return; }
  const id   = document.getElementById("fId").value;
  const body = {
    name, host,
    description:       document.getElementById("fDesc").value.trim(),
    tags:              document.getElementById("fTags").value.split(",").map(t=>t.trim()).filter(Boolean),
    checks:            currentChecks.map(c => ({...c})),
    group_ids:         Array.from(serverPickedGroups),
    poll_interval_sec: parseInt(document.getElementById("fInterval").value) || 30
  };
  try {
    const r = await fetch(id ? `/api/admin/servers/${id}` : "/api/admin/servers", {
      method: id ? "PUT" : "POST",
      headers:{"Content-Type":"application/json"},
      body: JSON.stringify(body)
    });
    const d = await r.json();
    if (!r.ok){ document.getElementById("fErr").textContent = d.error||"Failed"; return; }
    cacheDel("admin-servers");
    cacheDel("admin-groups");
    toast(id ? "Server updated" : "Server added", "success");
    // If we came from the Omada sites browser, return there instead of the Servers tab
    if (serverFormReturn && serverFormReturn.type === "omada-sites" && serverFormReturn.controller) {
      const ctrl = serverFormReturn.controller;
      serverFormReturn = null;
      showOmadaSites(ctrl);
    } else {
      showList();
    }
  } catch(e){ document.getElementById("fErr").textContent = "Error: "+e.message; }
}

function askDel(id, name){
  pendDel = id;
  document.getElementById("confirmMsg").textContent = `"${name}" will be removed.`;
  document.getElementById("confirmDlg").classList.add("open");
  document.querySelector("#confirmDlg .btn-danger").onclick = doDelete;
}
function closeConfirm(){
  document.getElementById("confirmDlg").classList.remove("open");
  pendDel = null; pendDelUser = null; pendDelGroup = null; pendDelOmada = null;
}
async function doDelete(){
  if (!pendDel) return;
  try {
    const r = await fetch(`/api/admin/servers/${pendDel}`, {method:"DELETE"});
    const d = await r.json();
    if (r.ok) { cacheDel("admin-servers"); cacheDel("admin-groups"); }
    toast(r.ok ? "Server removed" : (d.error||"Failed"), r.ok ? "info" : "error");
  } catch(e){ toast("Error: "+e.message, "error"); }
  closeConfirm();
  loadServerList();
}

// ── User list ─────────────────────────────────────────────────────────────────
function renderAdminUserList(users){
  const el = document.getElementById("adminPanelBody");
  _userStore = {};
  users.forEach(u => _userStore[u.id] = u);
  document.getElementById("aCount").textContent = `${users.length} user${users.length===1?"":"s"}`;
  if (!users.length){ el.innerHTML = `<div class="empty-state">No users found.</div>`; return; }
  // Build a group-id → group lookup from the cached groups list (loaded by ensureGroupsLoaded)
  const groupById = {};
  adminGroups.forEach(g => { groupById[g.id] = g; });
  el.innerHTML = users.map(u => {
    // Dashboard pills: admin = "All", viewer = pills for each allowed group
    let pillsHtml;
    if (u.role === "admin") {
      pillsHtml = `<span class="user-dash-pill user-dash-all">All dashboards</span>`;
    } else {
      const ids = u.allowed_group_ids || [];
      if (!ids.length) {
        pillsHtml = `<span class="user-dash-pill user-dash-none">No dashboards assigned</span>`;
      } else {
        pillsHtml = ids.map(gid => {
          const g = groupById[gid];
          const name = g ? g.name : `#${gid}`;
          const color = g && g.accent_color ? g.accent_color : "var(--blue)";
          return `<span class="user-dash-pill" style="border-color:${color};color:${color}">${name}</span>`;
        }).join("");
      }
    }
    return `<div class="user-item" onclick="showUserForm(_userStore[${u.id}])">
      <div class="user-avatar">${(u.username||"?")[0].toUpperCase()}</div>
      <div class="user-info">
        <div class="user-name">${u.username}</div>
        <div class="user-meta">Created ${new Date(u.created_at).toLocaleDateString()}</div>
        <div class="user-dash-pills">${pillsHtml}</div>
      </div>
      <span class="role-badge ${u.role}">${u.role}</span>
      <div class="admin-row-actions" onclick="event.stopPropagation()">
        <button class="btn btn-sm" onclick="showUserForm(_userStore[${u.id}])">Edit</button>
        <button class="btn btn-sm btn-danger" onclick="askDelUser(${u.id})">Remove</button>
      </div>
    </div>`;
  }).join("");
}

async function loadUserList(){
  const el = document.getElementById("adminPanelBody");

  // Make sure groups are loaded so user rows can render dashboard pills with real names
  await ensureGroupsLoaded();

  // 1) Instant render from cache
  const cached = cacheGet("admin-users");
  if (cached) renderAdminUserList(cached);
  else        el.innerHTML = `<div style="padding:24px;text-align:center;color:var(--text-2)">Loading users...</div>`;

  // 2) Fetch fresh
  try {
    const r = await fetch("/api/admin/users");
    if (r.status === 401){ window.location.href = "/"; return; }
    if (r.status === 403){
      if (!cached) el.innerHTML = `<div class="empty-state">Admin role required. Log out and back in.</div>`;
      return;
    }
    if (!r.ok){
      if (!cached) el.innerHTML = `<div class="empty-state">Error ${r.status}</div>`;
      return;
    }
    const users = await r.json();
    cacheSet("admin-users", users);
    renderAdminUserList(users);
  } catch(e){
    if (!cached) el.innerHTML = `<div class="empty-state">Failed: ${e.message}</div>`;
  }
}

// ── User form ─────────────────────────────────────────────────────────────────
// Tracks the in-form selection of allowed group ids for the user being edited
let userPickedGroups = new Set();

async function showUserForm(u){
  document.getElementById("aListView").style.display     = "none";
  document.getElementById("aFormView").style.display     = "none";
  document.getElementById("aUserFormView").style.display = "flex";
  document.getElementById("uFormHeading").textContent    = u ? "Edit User" : "Add User";
  document.getElementById("uId").value       = u?.id       || "";
  document.getElementById("uName").value     = u?.username || "";
  document.getElementById("uRole").value     = u?.role     || "viewer";
  document.getElementById("uPassword").value = "";
  document.getElementById("uPwdHint").textContent = u ? "(leave blank to keep current)" : "(required)";
  document.getElementById("uErr").textContent = "";
  // Pre-select the user's existing allowed groups
  userPickedGroups = new Set(u?.allowed_group_ids || []);
  // Make sure groups are loaded so the picker can render them
  await ensureGroupsLoaded();
  renderUserGroupsPicker();
  onUserRoleChange();
}

// Hide the Allowed Dashboards row when role=admin (admins see everything)
function onUserRoleChange(){
  const role = document.getElementById("uRole").value;
  document.getElementById("uGroupsRow").style.display = role === "admin" ? "none" : "block";
}

function renderUserGroupsPicker(){
  const el = document.getElementById("uGroupsPicker");
  if (!adminGroups.length) {
    el.innerHTML = `<div style="padding:14px;color:var(--text-2);font-size:12px;text-align:center">No dashboards yet. Create one in the Groups tab first.</div>`;
    return;
  }
  el.innerHTML = adminGroups.map(g => `
    <label style="display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;cursor:pointer;font-size:12px;color:var(--text-hi)">
      <input type="checkbox" value="${g.id}" ${userPickedGroups.has(g.id) ? "checked" : ""} onchange="toggleUserGroup(${g.id}, this.checked)">
      <span style="flex:1">${g.name} <span style="color:var(--text-2);font-size:11px">/dashboard/${g.slug}</span></span>
    </label>
