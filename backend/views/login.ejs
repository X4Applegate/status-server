<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Applegate Monitor — Login</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root,[data-theme="dark"]{--bg:#0b0e14;--surface:#141920;--surface2:#1a2030;--border:rgba(255,255,255,0.08);--border-hi:rgba(255,255,255,0.14);--text:#94a3b8;--text-2:#64748b;--text-hi:#e2e8f0;--text-white:#f8fafc;--shadow:rgba(0,0,0,0.4);--input-bg:#0f1318;--ga:rgba(99,102,241,0.1)}
[data-theme="light"]{--bg:#f4f6f9;--surface:#fff;--surface2:#f0f3f7;--border:rgba(0,0,0,0.08);--border-hi:rgba(0,0,0,0.14);--text:#5a6a7e;--text-2:#8fa0b5;--text-hi:#2d3a4a;--text-white:#1a2535;--shadow:rgba(0,0,0,0.1);--input-bg:#f8fafc;--ga:rgba(99,102,241,0.06)}
:root{--accent:#6366f1;--accent-soft:rgba(99,102,241,0.12);--down:#ef4444;--sans:'Plus Jakarta Sans',sans-serif;--mono:'JetBrains Mono',monospace;--r:12px;--r-sm:8px}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;display:flex;align-items:center;justify-content:center;-webkit-font-smoothing:antialiased}
.bg-glow{position:fixed;inset:0;pointer-events:none;background:radial-gradient(ellipse 70% 60% at 50% 30%,var(--ga) 0%,transparent 70%)}
.card{position:relative;z-index:1;width:100%;max-width:380px;margin:24px;background:var(--surface);border:1px solid var(--border-hi);border-radius:var(--r);padding:36px 32px;box-shadow:0 20px 60px var(--shadow)}
.brand{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:28px}
.brand-icon{width:36px;height:36px;border-radius:9px;background:var(--accent-soft);border:1px solid rgba(99,102,241,.25);display:flex;align-items:center;justify-content:center;font-size:16px}
.brand-name{font-size:18px;font-weight:700;color:var(--text-white);letter-spacing:-.02em}
.brand-name span{color:var(--accent)}
.heading{font-size:15px;font-weight:600;color:var(--text-white);text-align:center;margin-bottom:6px}
.subhead{font-size:13px;color:var(--text-2);text-align:center;margin-bottom:24px}
.form-group{display:flex;flex-direction:column;gap:6px;margin-bottom:14px}
.label{font-size:11px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--text-2)}
.input{width:100%;padding:10px 13px;background:var(--input-bg);border:1px solid var(--border-hi);border-radius:var(--r-sm);color:var(--text-white);font-family:var(--sans);font-size:14px;outline:none;transition:border-color .15s,box-shadow .15s}
.input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(99,102,241,.15)}
.input::placeholder{color:var(--text-2)}
.btn-login{width:100%;padding:11px;background:var(--accent);border:none;border-radius:var(--r-sm);color:#fff;font-family:var(--sans);font-size:14px;font-weight:600;cursor:pointer;margin-top:8px;transition:background .15s,transform .1s}
.btn-login:hover{background:#5254cc}
.btn-login:active{transform:scale(.98)}
.btn-login:disabled{opacity:.6;cursor:not-allowed}
.error{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.25);border-radius:var(--r-sm);padding:10px 13px;font-size:13px;color:#fca5a5;margin-top:12px;display:none}
.error.show{display:block}
.theme-toggle{position:fixed;top:16px;right:16px;width:34px;height:34px;border-radius:8px;border:1px solid var(--border-hi);background:var(--surface);color:var(--text-hi);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;z-index:10}
[data-theme="light"] .icon-moon{display:none}
[data-theme="dark"] .icon-sun{display:none}
</style>
</head>
<body>
<div class="bg-glow"></div>
<button class="theme-toggle" onclick="toggleTheme()">
  <span class="icon-sun"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg></span>
  <span class="icon-moon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span>
</button>
<div class="card">
  <div class="brand">
    <div class="brand-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5"/></svg></div>
    <div class="brand-name">Applegate<span>Monitor</span></div>
  </div>
  <div class="heading" id="formHeading">Welcome back</div>
  <div class="subhead" id="formSubhead">Sign in to access the admin panel</div>
  <div class="form-group">
    <label class="label">Username</label>
    <input class="input" id="username" type="text" placeholder="Choose a username" autocomplete="username">
  </div>
  <div class="form-group">
    <label class="label">Password</label>
    <div style="position:relative">
    <input class="input" id="password" type="password" placeholder="Enter password" autocomplete="current-password" style="padding-right:40px">
    <button type="button" onclick="togglePwd()" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-2);padding:4px;display:flex;align-items:center" id="pwdToggle">
      <svg id="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
    </button>
  </div>
  </div>
  <div class="form-group" id="confirmGroup" style="display:none">
    <label class="label">Confirm Password</label>
    <input class="input" id="confirmPassword" type="password" placeholder="Confirm password" autocomplete="new-password">
  </div>
  <div id="turnstileWrap" style="display:none;margin-top:4px;margin-bottom:4px"></div>
  <button class="btn-login" id="loginBtn" onclick="doLogin()">Sign In</button>
  <div class="error" id="errorMsg"></div>
</div>
<script>
const html = document.documentElement;
html.setAttribute("data-theme", localStorage.getItem("sm-theme") || "dark");
function toggleTheme(){const n=html.getAttribute("data-theme")==="dark"?"light":"dark";html.setAttribute("data-theme",n);localStorage.setItem("sm-theme",n)}

let setupMode = false;
let turnstileWidgetId = null;
let turnstileSiteKey  = "";

function renderTurnstile(){
  if (!turnstileSiteKey || !window.turnstile) return;
  const wrap = document.getElementById("turnstileWrap");
  wrap.style.display = "block";
  wrap.innerHTML = "";
  turnstileWidgetId = window.turnstile.render(wrap, {
    sitekey: turnstileSiteKey,
    theme: "auto",
    size: "flexible"
  });
}

// Check if this is a fresh install (no users) or existing install
(async () => {
  // Redirect if already logged in
  try {
    const meRes = await fetch("/api/me");
    const me = await meRes.json();
    if (me.loggedIn) { window.location.href = me.login_redirect || "/"; return; }
  } catch(e) {}

  // Check if setup is needed
  try {
    const r = await fetch("/api/setup-status");
    const d = await r.json();
    if (d.needsSetup) {
      setupMode = true;
      document.getElementById("formHeading").textContent = "Create Admin Account";
      document.getElementById("formSubhead").textContent = "Set up your first admin account to get started";
      document.getElementById("confirmGroup").style.display = "flex";
      document.getElementById("loginBtn").textContent = "Create Account";
      document.getElementById("username").placeholder = "Choose a username";
      document.getElementById("password").autocomplete = "new-password";
    }
  } catch(e) {}

  // Load Cloudflare Turnstile widget if the admin has enabled it.
  // Skipped during setup mode — no admin exists yet to configure it.
  if (!setupMode) {
    try {
      const r = await fetch("/api/turnstile-config");
      const d = await r.json();
      if (d.enabled && d.site_key) {
        turnstileSiteKey = d.site_key;
        const s = document.createElement("script");
        s.src = "https://challenges.cloudflare.com/turnstile/v0/api.js?onload=onTurnstileReady";
        s.async = true; s.defer = true;
        document.head.appendChild(s);
      }
    } catch(e) {}
  }
})();

window.onTurnstileReady = renderTurnstile;

document.getElementById("password").addEventListener("keydown", e => {
  if (e.key === "Enter") {
    if (setupMode) document.getElementById("confirmPassword").focus();
    else doLogin();
  }
});
document.getElementById("username").addEventListener("keydown", e => { if(e.key==="Enter") document.getElementById("password").focus(); });
document.getElementById("confirmPassword").addEventListener("keydown", e => { if(e.key==="Enter") doLogin(); });

function togglePwd(){
  const input = document.getElementById("password");
  const icon  = document.getElementById("eyeIcon");
  if(input.type === "password"){
    input.type = "text";
    icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
  } else {
    input.type = "password";
    icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
  }
}

async function doLogin(){
  const btn=document.getElementById("loginBtn");
  const err=document.getElementById("errorMsg");
  const username=document.getElementById("username").value.trim();
  const password=document.getElementById("password").value;
  if(!username||!password){err.textContent="Please enter username and password.";err.classList.add("show");return}

  if (setupMode) {
    const confirm = document.getElementById("confirmPassword").value;
    if (password !== confirm) { err.textContent="Passwords do not match.";err.classList.add("show");return; }
    btn.disabled=true;btn.textContent="Creating account…";err.classList.remove("show");
    try {
      const r = await fetch("/api/setup", {method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({username,password})});
      const data = await r.json();
      if (!r.ok) { err.textContent=data.error||"Setup failed";err.classList.add("show");btn.disabled=false;btn.textContent="Create Account";return; }
      window.location.href = data.redirect || "/";
    } catch(e) {
      err.textContent="Connection error — try again";err.classList.add("show");btn.disabled=false;btn.textContent="Create Account";
    }
    return;
  }

  let turnstile_token = "";
  if (turnstileSiteKey) {
    if (window.turnstile && turnstileWidgetId !== null) {
      turnstile_token = window.turnstile.getResponse(turnstileWidgetId) || "";
    }
    if (!turnstile_token) {
      err.textContent = "Please complete the captcha.";
      err.classList.add("show");
      return;
    }
  }

  btn.disabled=true;btn.textContent="Signing in…";err.classList.remove("show");
  try{
    const r=await fetch("/api/login",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({username,password,turnstile_token})});
    const data=await r.json();
    if(!r.ok){
      err.textContent=data.error||"Login failed";err.classList.add("show");
      btn.disabled=false;btn.textContent="Sign In";
      if (window.turnstile && turnstileWidgetId !== null) window.turnstile.reset(turnstileWidgetId);
      return;
    }
    window.location.href = data.redirect || "/";
  }catch(e){
    err.textContent="Connection error — try again";err.classList.add("show");btn.disabled=false;btn.textContent="Sign In";
    if (window.turnstile && turnstileWidgetId !== null) window.turnstile.reset(turnstileWidgetId);
  }
}
</script>
<div style="position:fixed;bottom:16px;left:50%;transform:translateX(-50%);font-size:11px;color:var(--text-2)"><a href="https://github.com/X4Applegate/status-server" target="_blank" rel="noopener" style="color:var(--text-2);text-decoration:none;display:inline-flex;align-items:center;gap:5px" onmouseover="this.style.color='var(--text-hi)'" onmouseout="this.style.color='var(--text-2)'"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.929.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.216.694.825.576C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>Applegate Monitor on GitHub</a></div>
</body>
</html>