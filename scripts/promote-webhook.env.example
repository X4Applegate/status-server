# promote-webhook.env — config for scripts/promote-webhook.service
#
# Install to /etc/status-server/promote-webhook.env with mode 600.
# Contains the shared secret and DB root password — DO NOT commit a filled
# copy of this file.

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Shared bearer token. Callers must send it on POST /promote as either:
#   X-Promote-Token: <this value>    ← preferred (custom header)
#   cf-webhook-auth: <this value>    ← for Cloudflare Notification Webhooks,
#                                      which use this header name natively so
#                                      you can point CF directly at this
#                                      endpoint without a Worker in front.
# The webhook accepts whichever is present — use ONE depending on caller.
# Generate with:  openssl rand -hex 32
PROMOTE_SHARED_SECRET=REPLACE_WITH_openssl_rand_hex_32

# MariaDB root password — passed through to promote-replica.sh.
# Must match /root/.promote-replica.env if you also run the script manually.
MARIADB_ROOT_PASSWORD=REPLACE_WITH_DB_ROOT_PASSWORD

# ── STRONGLY RECOMMENDED — split-brain guard ────────────────────────────────
# Before promoting, the webhook GETs each URL below and refuses to promote
# if ANY return 2xx. Pass URLs that route via DIFFERENT network paths so
# a single partition can't look like a primary outage.
#
# Typical pattern — two vantage points:
#   1. Primary's public URL (via Cloudflare edge → primary's tunnel connector)
#   2. Primary's direct IP (via VPN/LAN — different network path than CF)
#
# If you have a third observer box, add its URL too for extra confidence.
#
# Operators can override a guard block with {"force":true} in the POST body.
#
# PROMOTE_PRIMARY_CHECKS=https://gateway.example.com/health,http://10.0.0.1:3200/health

# Per-check timeout. Default 5s balances "catch a genuinely-dead primary"
# with "don't block legitimate promotion for too long."
# PROMOTE_CHECKS_TIMEOUT_MS=5000

# NUCLEAR option — disable the split-brain guard entirely. Only use for
# drills/tests. Default unset (guard enabled if checks are configured).
# PROMOTE_CHECKS_BYPASS=0

# ── OPTIONAL (defaults shown) ────────────────────────────────────────────────

# Port the webhook listens on. 127.0.0.1:9876 means no external traffic can
# reach it directly — the Cloudflare Worker must route through a tunnel or
# Access-protected hostname that terminates on the host.
# PROMOTE_WEBHOOK_BIND=127.0.0.1
# PROMOTE_WEBHOOK_PORT=9876

# Absolute path to the promote script.
# PROMOTE_SCRIPT_PATH=/opt/status-server/scripts/promote-replica.sh

# How long to refuse repeated promotions after a successful one. Prevents
# ping-pong if both sides briefly see each other as down. 300s = 5 minutes.
# PROMOTE_COOLDOWN_SECONDS=300

# Where to persist the last-promoted timestamp (survives webhook restart).
# PROMOTE_STATE_FILE=/var/lib/status-server/promote-webhook.state

# How long to wait for the promote script before giving up. 120s should
# cover the slowest path (docker start + health probe + cloudflared boot).
# PROMOTE_TIMEOUT_MS=120000

# Which systemd unit the promote script should start/enable. Usually
# 'cloudflared'. Set to an empty string to skip the tunnel step (e.g. if
# you front traffic with a Cloudflare Load Balancer instead of a Tunnel).
# CLOUDFLARED_SVC=cloudflared

# Override the status-server compose directory if different from the default.
# COMPOSE_DIR=/opt/status-server
# DB_CONTAINER=mariadb
# APP_CONTAINER=status-server
